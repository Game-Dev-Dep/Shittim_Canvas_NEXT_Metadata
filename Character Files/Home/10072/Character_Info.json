            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 10072,
            "CostumeUniqueId": 1007201,
            "DisplayOrder": 430,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 2,
            "ActionName": "",
            "DialogType": 1,
            "Duration": 9500,
            "LocalizeKR": "(후훗, 역시 선생님이야.\n 배우는 속도가 빠르네.)",
            "LocalizeJP": "（ふふっ、\nさすが先生。\n習得が早いな）",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle2",
            "AnimationName": "Talk_02_M",
            "Anniversary": 0,
