            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle4",
            "AnimationName": "Talk_04_M",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 10127,
            "CostumeUniqueId": 1012701,
            "DisplayOrder": 330,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 4,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 10100,
            "LocalizeKR": "한 번도 저한테\n연락 주지 않으셨잖아요.",
            "LocalizeJP": "一度も、\n私に連絡しなかったから。",
