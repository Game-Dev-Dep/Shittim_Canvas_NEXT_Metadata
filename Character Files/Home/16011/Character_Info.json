            "DisplayOrder": 300,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 2,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 13100,
            "LocalizeKR": "선생님, 죄송합니다…\n보시다시피 이런\n상황이 되어 버려서…",
            "LocalizeJP": "先生、すみません…\nご覧の通り、このような\n状況となってしまいまして…",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle2",
            "AnimationName": "",
            "Anniversary": 0,
