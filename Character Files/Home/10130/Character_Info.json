            "DisplayOrder": 470,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 1,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 13020,
            "LocalizeKR": "이렇게 한 사람을 위해\n연주하는 건 처음이라……",
            "LocalizeJP": "こうして誰か一人のために\n演奏するのは初めてで……。",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle1",
            "AnimationName": "",
            "Anniversary": 0,
