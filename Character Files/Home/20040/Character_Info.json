            "DisplayOrder": 500,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 3,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 15460,
            "LocalizeKR": "큭…… 나는…… 선생님을……\n괴롭히지…… 않겠습니다아……",
            "LocalizeJP": "くっ……私は……先生に……\n意地悪……しませ、ん……",
            "VoiceIds": [],
            "CollectionVisible": false,
