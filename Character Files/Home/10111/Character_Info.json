            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 5,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 4450,
            "LocalizeKR": "하하! 그렇게\n말할 줄 알았어!",
            "LocalizeJP": "ははっ！\nそう言うと思った！",
            "VoiceIds": [],
            "CollectionVisible": false,
