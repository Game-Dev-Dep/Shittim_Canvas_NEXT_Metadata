            "GroupId": 1,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 6500,
            "LocalizeKR": "(훗, 내 일하는 모습에\n반하면 곤란하다고?)",
            "LocalizeJP": "（ふふっ、私の働く姿に\n見惚れちゃ困るわよ？）",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle1",
            "AnimationName": "Talk_01_M",
            "Anniversary": 0,
