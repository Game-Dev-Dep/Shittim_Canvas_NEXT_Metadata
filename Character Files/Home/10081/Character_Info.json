  "Subtitles": {
    "Entries": [
      {
        "Region": 3,
        "CharacterDialogInfo_List": [
          {
            "CharacterId": 10081,
            "CostumeUniqueId": 1008101,
            "DisplayOrder": 410,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 1,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 9833,
            "LocalizeKR": "우후훗, 여기여요,\n소녀는 여기 있사와요. 선생님.",
            "LocalizeJP": "うふふっ、ここです、\n身共はここにおりますわ、先生。",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle1",
            "AnimationName": "Talk_01_M",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 10081,
            "CostumeUniqueId": 1008101,
            "DisplayOrder": 420,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 2,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 4000,
            "LocalizeKR": "괜찮답니다.\n그렇게 오래 기다리진\n않았사와요.",
            "LocalizeJP": "大丈夫です、\nそれほど待っておりませんの。",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle2",
            "AnimationName": "Talk_02_M",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 10081,
            "CostumeUniqueId": 1008101,
            "DisplayOrder": 430,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 2,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 11167,
            "LocalizeKR": "약조하였던 시간보다\n고작 1시간 정도 일찍\n발걸음을 옮겼을 뿐이기에.",
            "LocalizeJP": "約束の時刻より、\nほんの1時間ほど\n早く足を運んでしまった\nだけですから。",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle2",
            "AnimationName": "",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 10081,
            "CostumeUniqueId": 1008101,
            "DisplayOrder": 440,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 3,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 6100,
            "LocalizeKR": "아뇨, 뭔가\n특별한 이유가 있어\n그런 게 아니라, 단지……",
            "LocalizeJP": "いえ、何か特別な\n理由があるわけではなく、\nただ……。",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle3",
            "AnimationName": "Talk_03_M",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 10081,
            "CostumeUniqueId": 1008101,
            "DisplayOrder": 450,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 3,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 8900,
            "LocalizeKR": "오늘은 어디를 갈까.\n무엇을 할까.\n또 어떤 새로운 것을\n가르쳐 주실까.",
            "LocalizeJP": "本日はどこへ足を運ぼうか、\n何をしようか、また新しい事を\nご教示いただけるだろうか……",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle3",
            "AnimationName": "",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 10081,
            "CostumeUniqueId": 1008101,
            "DisplayOrder": 460,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 3,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 11333,
            "LocalizeKR": "그런 생각을 했더니,\n얌전히 기다릴 수가\n없어서……",
            "LocalizeJP": "そんなふうに考え始めたら、\nいても立っても\nいられなくなってしまって……。",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle3",
            "AnimationName": "",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 10081,
            "CostumeUniqueId": 1008101,
            "DisplayOrder": 470,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 4,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 7200,
            "LocalizeKR": "아, 말씀드리자면.\n소녀는 이렇게 기다리는 시간도\n좋아한답니다?",
            "LocalizeJP": "あ、申し上げておきますが、\n身共はこうして待っている\n時間というのも好きなのですよ？",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle4",
            "AnimationName": "Talk_04_M",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 10081,
            "CostumeUniqueId": 1008101,
            "DisplayOrder": 480,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 4,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 11967,
            "LocalizeKR": "선생님과 함께라면,\n기다리는 시간조차 두근거리는\n멋진 시간이 될 테니까요.",
            "LocalizeJP": "先生と共に在れるのであれば、\n待ち時間さえも鼓動高鳴る\nすてきなひと時となりますから。",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle4",
            "AnimationName": "",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 10081,
            "CostumeUniqueId": 1008101,
            "DisplayOrder": 490,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 5,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 3500,
            "LocalizeKR": "자아. 이러고 있을 때가\n아니어요!",
            "LocalizeJP": "さ、こうしている\n場合じゃありませんの！",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle5",
            "AnimationName": "Talk_05_M",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 10081,
            "CostumeUniqueId": 1008101,
            "DisplayOrder": 500,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 5,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 12000,
            "LocalizeKR": "후훗, 오늘도 소녀에게,\n눈부시게 아름다운 세계를\n가르쳐 주시와요! 선생님!",
            "LocalizeJP": "ふふっ！本日も身共に、\n眩く美しい世界を\n教えてくださいまし！先生！",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle5",
            "AnimationName": "",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          }
        ],
