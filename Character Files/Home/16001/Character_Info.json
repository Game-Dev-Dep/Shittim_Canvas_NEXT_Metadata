          },
          {
            "CharacterId": 16001,
            "CostumeUniqueId": 1600101,
            "DisplayOrder": 290,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 2,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 9050,
            "LocalizeKR": "…뭐, 어때! 쨔안-!\n언제나의 아스나 쨩으로, 부활!",
            "LocalizeJP": "…まあ良いか！じゃーん！\nいつものアスナちゃん、復活！",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle2",
            "AnimationName": "",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
