            "DisplayOrder": 310,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 3,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 4500,
            "LocalizeKR": "그러잖아도 바쁘실 텐데,",
            "LocalizeJP": "そうでなくても\nお忙しいのに…",
            "VoiceIds": [],
            "CollectionVisible": false,
