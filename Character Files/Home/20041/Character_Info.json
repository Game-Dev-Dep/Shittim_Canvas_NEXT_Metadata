            "DisplayOrder": 620,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 4,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 5760,
            "LocalizeKR": "이…… 이해할 수 없어.\n그런……",
            "LocalizeJP": "り……理解に苦しむわ……\nでも……",
            "VoiceIds": [],
            "CollectionVisible": false,
