            "GroupId": 2,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 5070,
            "LocalizeKR": "크루세이더 쨩을,\n녹슬게 할 순 없으니까요.",
            "LocalizeJP": "クルセイダーちゃんを、\n錆びさせるわけには\nいきませんからね。",
            "VoiceIds": [],
            "CollectionVisible": false,
