            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 10132,
            "CostumeUniqueId": 1013201,
            "DisplayOrder": 410,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 4,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 11100,
            "LocalizeKR": "네?! 펜스 옆에\n쪽문이……?!",
            "LocalizeJP": "えっ？\nフェンスの横に、\nくぐり戸……！？",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle4",
            "AnimationName": "",
            "Anniversary": 0,
