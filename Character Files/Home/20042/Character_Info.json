            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 3,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 2360,
            "LocalizeKR": "묘한 승부욕이 생기더라고.",
            "LocalizeJP": "妙に競争心が湧いちゃって。",
            "VoiceIds": [],
            "CollectionVisible": false,
