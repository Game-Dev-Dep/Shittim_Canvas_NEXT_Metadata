                        "DialogCategory": 8,
                        "DialogCondition": 0,
                        "GroupId": 5,
                        "ActionName": "",
                        "DialogType": 0,
                        "Duration": 9670,
                        "LocalizeKR": "……이 동맹은,\n영원한 거야.",
