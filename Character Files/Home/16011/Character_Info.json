            "DisplayOrder": 330,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 4,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 4900,
            "LocalizeKR": "작년만 해도\n곧잘 입던 옷이었는데",
            "LocalizeJP": "去年まではよく\n着ていた服のはずなのに…",
