            "ActionName": "",
            "DialogType": 0,
            "Duration": 3900,
            "LocalizeKR": "아, 아하하……",
            "LocalizeJP": "あ、あはは……。",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle5",
