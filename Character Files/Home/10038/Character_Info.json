            "GroupId": 1,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 2500,
            "LocalizeKR": "예뻐라…",
            "LocalizeJP": "綺麗……。",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle1",
            "AnimationName": "Talk_01_M",
            "Anniversary": 0,
            "StartDate": "",
