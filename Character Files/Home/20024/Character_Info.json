    "Entries": [
      {
        "Region": 3,
        "CharacterDialogInfo_List": [
          {
            "CharacterId": 20024,
            "CostumeUniqueId": 2002401,
            "DisplayOrder": 390,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 1,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 9200,
            "LocalizeKR": "후후… 은은하게 풍기는\n베르가모트의 풍미가\n상쾌하니 좋네요.",
            "LocalizeJP": "ふふっ……ほのかに香る\nベルガモットの風味が、\n爽やかで良いですね。",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle1",
            "AnimationName": "Talk_01_M",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 20024,
            "CostumeUniqueId": 2002401,
            "DisplayOrder": 400,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 1,
            "ActionName": "",
            "DialogType": 1,
            "Duration": 12633,
            "LocalizeKR": "(이건, 역시 다시마……\n속일 수 없는 향기가\n나고 있어요…)",
            "LocalizeJP": "（……これは、やはり昆布……\n誤魔化しようのない\n香りがしますね……）",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle1",
            "AnimationName": "",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 20024,
            "CostumeUniqueId": 2002401,
            "DisplayOrder": 410,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 2,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 8100,
            "LocalizeKR": "특유의 산뜻한\n뒷맛이 다과와\n정말 잘 어울려서…",
            "LocalizeJP": "このすっきりとした後味が、\nお茶菓子にとても\nよく合いますね……。",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle2",
            "AnimationName": "Talk_02_M",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 20024,
            "CostumeUniqueId": 2002401,
            "DisplayOrder": 420,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 2,
            "ActionName": "",
            "DialogType": 1,
            "Duration": 10567,
            "LocalizeKR": "(다시마의 맛이 너무\n강해서…… 입 안에서 과자의\n맛과 충돌하고 있어……)",
            "LocalizeJP": "（昆布の出汁が強すぎて、\n口内でお菓子の\n味と喧嘩を……）",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle2",
            "AnimationName": "",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 20024,
            "CostumeUniqueId": 2002401,
            "DisplayOrder": 430,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 3,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 6800,
            "LocalizeKR": "선생님께서도\n이런 맛은 처음이신가요?",
            "LocalizeJP": "……？先生にとっても\n初めての味わいでしたか？",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle3",
            "AnimationName": "Talk_03_M",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 20024,
            "CostumeUniqueId": 2002401,
            "DisplayOrder": 440,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 3,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 12700,
            "LocalizeKR": "그, 그렇겠지요…\n쉽게 구할 수 없는 종류의\n찻잎이기도 하고… 후,후후…",
            "LocalizeJP": "そ、そうでしょうね……\nあまり手に入らないタイプの\n茶葉ですし……ふ、ふふ……。",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle3",
            "AnimationName": "",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 20024,
            "CostumeUniqueId": 2002401,
            "DisplayOrder": 450,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 4,
            "ActionName": "",
            "DialogType": 1,
            "Duration": 11333,
            "LocalizeKR": "(……들킨 건 아니겠지요?\n향기는 좀 그렇지만,\n색만큼은 그럴싸하니까……)",
            "LocalizeJP": "（……バレてませんよね？\n香りはちょっとアレですが、\n色はそれっぽいですし……）",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle4",
            "AnimationName": "Talk_04_M",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 20024,
            "CostumeUniqueId": 2002401,
            "DisplayOrder": 460,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 5,
            "ActionName": "",
            "DialogType": 1,
            "Duration": 11500,
            "LocalizeKR": "(이럴 줄 알았으면 무리하지\n말고 평범한 홍차를\n시킬 걸 그랬어요……)",
            "LocalizeJP": "（こうなると分かっていたら、\n無理をせずに普通の紅茶を\n頼んでおけば……）",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle5",
            "AnimationName": "Talk_05_M",
