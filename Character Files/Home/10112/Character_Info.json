            "DisplayOrder": 410,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 4,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 8800,
            "LocalizeKR": "강아지랑\n산책하는 것 같아!",
