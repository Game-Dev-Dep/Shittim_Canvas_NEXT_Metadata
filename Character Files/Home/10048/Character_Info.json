            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 3,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 5000,
            "LocalizeKR": "그저 내 마무리가\n어설펐을 뿐이야……",
