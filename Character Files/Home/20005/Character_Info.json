            "DisplayOrder": 280,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 2,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 8000,
            "LocalizeKR": "원래 모두가 함께\n사용하는 물건이고\n깨끗이 제자리에\n돌려놔야 할 텐데.",
            "LocalizeJP": "そもそもみんな\nで使うものですし、\nキレイな状態で\n学園に戻さないと。",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle2",
            "AnimationName": "",
            "Anniversary": 0,
