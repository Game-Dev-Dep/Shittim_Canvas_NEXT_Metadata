            "DisplayOrder": 450,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 6,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 7170,
            "LocalizeKR": "저 숱한 별들 중\n가장 가냘프고 빛나는\n별님 하나가.",
            "LocalizeJP": "あの中で一番美しく\n輝いている星が……",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle6",
            "AnimationName": "Talk_06_M",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
