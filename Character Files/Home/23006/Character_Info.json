            "DisplayOrder": 360,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 3,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 11500,
            "LocalizeKR": "참 신기해요.\n이런 거, 원래는 해서는\n안 되는 일인데…",
            "LocalizeJP": "……不思議ですね。こういう\nことはしちゃいけないって、\n気を張ってなきゃって、ずっと\n思ってたはずなんですが……。",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle3",
            "AnimationName": "Talk_03_M",
            "Anniversary": 0,
