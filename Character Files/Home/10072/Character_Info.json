            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 10072,
            "CostumeUniqueId": 1007201,
            "DisplayOrder": 440,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 3,
            "ActionName": "",
            "DialogType": 1,
            "Duration": 3800,
            "LocalizeKR": "(…뭔가 묘한 기분이네.)",
            "LocalizeJP": "（…なんか変な感じだ）",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle3",
            "AnimationName": "Talk_03_M",
