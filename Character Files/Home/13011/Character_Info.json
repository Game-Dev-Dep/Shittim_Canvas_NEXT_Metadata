            "DisplayOrder": 270,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 2,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 4400,
            "LocalizeKR": "불가능해 보일 것만\n같던 퀘스트였지만.",
