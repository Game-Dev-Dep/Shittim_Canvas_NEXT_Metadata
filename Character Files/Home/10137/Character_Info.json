          },
          {
            "CharacterId": 10137,
            "CostumeUniqueId": 1013701,
            "DisplayOrder": 390,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 1,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 9320,
            "LocalizeKR": "으으…… 추워.",
            "LocalizeJP": "うぅ……さっむ。",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle1",
            "AnimationName": "",
            "Anniversary": 0,
