            "DialogType": 0,
            "Duration": 5510,
            "LocalizeKR": "아하핫! 셔터 찬스, 잡았습니다!",
            "LocalizeJP": "あははっ！\nシャッターチャンス、\nとらえました！",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle1",
