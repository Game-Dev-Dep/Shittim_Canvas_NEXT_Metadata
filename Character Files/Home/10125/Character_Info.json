    "Subtitles": {
        "Entries": [
            {
                "Region": 3,
                "CharacterDialogInfo_List": [
                    {
                        "CharacterId": 10125,
                        "CostumeUniqueId": 1012501,
                        "DisplayOrder": 350,
                        "DialogCategory": 8,
                        "DialogCondition": 0,
                        "GroupId": 1,
                        "ActionName": "",
                        "DialogType": 0,
                        "Duration": 9590,
                        "LocalizeKR": "……처음 회화를 그렸을 때가\n생각나요.",
                        "LocalizeJP": "……はじめて絵を描いた日を、\n思い出します。",
                        "VoiceIds": [],
                        "CollectionVisible": false,
                        "CVCollectionType": 0,
                        "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle1",
                        "AnimationName": "Talk_01_M",
                        "Anniversary": 0,
                        "StartDate": "",
                        "EndDate": "",
                        "ApplyPosition": false,
                        "PosX": 0.0,
                        "PosY": 0.0,
                        "UnlockFavorRank": 0,
                        "UnlockEquipWeapon": false
                    },
                    {
                        "CharacterId": 10125,
                        "CostumeUniqueId": 1012501,
                        "DisplayOrder": 360,
                        "DialogCategory": 8,
                        "DialogCondition": 0,
                        "GroupId": 1,
                        "ActionName": "",
                        "DialogType": 0,
                        "Duration": 3230,
                        "LocalizeKR": "그때는…… \n정직하게, 순수하게",
                        "LocalizeJP": "あのときは……\nまっすぐ、純粋に、",
                        "VoiceIds": [],
                        "CollectionVisible": false,
                        "CVCollectionType": 0,
                        "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle1",
                        "AnimationName": "",
                        "Anniversary": 0,
                        "StartDate": "",
                        "EndDate": "",
                        "ApplyPosition": false,
                        "PosX": 0.0,
                        "PosY": 0.0,
                        "UnlockFavorRank": 0,
                        "UnlockEquipWeapon": false
                    },
                    {
                        "CharacterId": 10125,
                        "CostumeUniqueId": 1012501,
                        "DisplayOrder": 370,
                        "DialogCategory": 8,
                        "DialogCondition": 0,
                        "GroupId": 1,
                        "ActionName": "",
                        "DialogType": 0,
                        "Duration": 8100,
                        "LocalizeKR": "캔버스와 마주했었어요.",
                        "LocalizeJP": "キャンバスと\n向き合っていました。",
                        "VoiceIds": [],
                        "CollectionVisible": false,
                        "CVCollectionType": 0,
                        "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle1",
                        "AnimationName": "",
                        "Anniversary": 0,
                        "StartDate": "",
                        "EndDate": "",
                        "ApplyPosition": false,
                        "PosX": 0.0,
                        "PosY": 0.0,
                        "UnlockFavorRank": 0,
                        "UnlockEquipWeapon": false
                    },
                    {
                        "CharacterId": 10125,
                        "CostumeUniqueId": 1012501,
                        "DisplayOrder": 380,
                        "DialogCategory": 8,
                        "DialogCondition": 0,
                        "GroupId": 2,
                        "ActionName": "",
                        "DialogType": 0,
                        "Duration": 5070,
                        "LocalizeKR": "지금의 저는…… \n아닌 것 같아요.",
                        "LocalizeJP": "今の私は……違います。",
                        "VoiceIds": [],
                        "CollectionVisible": false,
                        "CVCollectionType": 0,
                        "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle2",
                        "AnimationName": "Talk_02_M",
                        "Anniversary": 0,
                        "StartDate": "",
                        "EndDate": "",
                        "ApplyPosition": false,
                        "PosX": 0.0,
                        "PosY": 0.0,
                        "UnlockFavorRank": 0,
                        "UnlockEquipWeapon": false
                    },
                    {
                        "CharacterId": 10125,
                        "CostumeUniqueId": 1012501,
                        "DisplayOrder": 390,
                        "DialogCategory": 8,
                        "DialogCondition": 0,
                        "GroupId": 2,
                        "ActionName": "",
                        "DialogType": 0,
                        "Duration": 11590,
                        "LocalizeKR": "무엇을 그리면 좋을지\n방황하다가, 자신감을 \n잃어버리게 되어서……",
                        "LocalizeJP": "何を描けばいいのか\n分からなくなって、\n自信を失ってしまって……。",
                        "VoiceIds": [],
                        "CollectionVisible": false,
                        "CVCollectionType": 0,
                        "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle2",
                        "AnimationName": "",
                        "Anniversary": 0,
                        "StartDate": "",
                        "EndDate": "",
                        "ApplyPosition": false,
                        "PosX": 0.0,
                        "PosY": 0.0,
                        "UnlockFavorRank": 0,
                        "UnlockEquipWeapon": false
                    },
                    {
                        "CharacterId": 10125,
                        "CostumeUniqueId": 1012501,
                        "DisplayOrder": 400,
                        "DialogCategory": 8,
                        "DialogCondition": 0,
                        "GroupId": 3,
                        "ActionName": "",
                        "DialogType": 0,
                        "Duration": 5580,
                        "LocalizeKR": "그러던 중,\n마스터께서 알려 주셨어요.",
                        "LocalizeJP": "そんなとき、\nマスターが教えてくれたんです。",
                        "VoiceIds": [],
                        "CollectionVisible": false,
                        "CVCollectionType": 0,
                        "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle3",
                        "AnimationName": "Talk_03_M",
                        "Anniversary": 0,
                        "StartDate": "",
                        "EndDate": "",
                        "ApplyPosition": false,
                        "PosX": 0.0,
                        "PosY": 0.0,
                        "UnlockFavorRank": 0,
                        "UnlockEquipWeapon": false
                    },
                    {
                        "CharacterId": 10125,
                        "CostumeUniqueId": 1012501,
                        "DisplayOrder": 410,
                        "DialogCategory": 8,
                        "DialogCondition": 0,
                        "GroupId": 3,
                        "ActionName": "",
                        "DialogType": 0,
                        "Duration": 11080,
                        "LocalizeKR": "<꿈>이라는 마법이,\n이미 마음속에 깃들어 있다고.",
                        "LocalizeJP": "「夢」という魔法は、\nもう心の中に宿ってるって。",
                        "VoiceIds": [],
                        "CollectionVisible": false,
                        "CVCollectionType": 0,
                        "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle3",
                        "AnimationName": "",
                        "Anniversary": 0,
                        "StartDate": "",
                        "EndDate": "",
                        "ApplyPosition": false,
                        "PosX": 0.0,
                        "PosY": 0.0,
                        "UnlockFavorRank": 0,
                        "UnlockEquipWeapon": false
                    },
                    {
                        "CharacterId": 10125,
                        "CostumeUniqueId": 1012501,
                        "DisplayOrder": 420,
                        "DialogCategory": 8,
                        "DialogCondition": 0,
                        "GroupId": 4,
                        "ActionName": "",
                        "DialogType": 0,
                        "Duration": 9020,
                        "LocalizeKR": "꿈이 있다면……\n더 이상, 길을 헤매는 일은\n없을 거예요.",
                        "LocalizeJP": "夢があるなら……これからは、\n道に迷わずに済みそうです。",
                        "VoiceIds": [],
                        "CollectionVisible": false,
                        "CVCollectionType": 0,
                        "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle4",
                        "AnimationName": "Talk_04_M",
                        "Anniversary": 0,
                        "StartDate": "",
                        "EndDate": "",
                        "ApplyPosition": false,
                        "PosX": 0.0,
                        "PosY": 0.0,
                        "UnlockFavorRank": 0,
                        "UnlockEquipWeapon": false
                    },
                    {
                        "CharacterId": 10125,
                        "CostumeUniqueId": 1012501,
                        "DisplayOrder": 430,
                        "DialogCategory": 8,
                        "DialogCondition": 0,
                        "GroupId": 4,
                        "ActionName": "",
                        "DialogType": 0,
                        "Duration": 13170,
                        "LocalizeKR": "마스터……\n괜찮다면, 저와 같은 길을\n걷지 않으시겠어요?",
                        "LocalizeJP": "マスター……\nよければ、私と同じ道を\n歩みませんか？",
                        "VoiceIds": [],
                        "CollectionVisible": false,
                        "CVCollectionType": 0,
                        "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle4",
                        "AnimationName": "",
                        "Anniversary": 0,
                        "StartDate": "",
                        "EndDate": "",
                        "ApplyPosition": false,
                        "PosX": 0.0,
                        "PosY": 0.0,
                        "UnlockFavorRank": 0,
                        "UnlockEquipWeapon": false
                    },
                    {
                        "CharacterId": 10125,
                        "CostumeUniqueId": 1012501,
                        "DisplayOrder": 440,
                        "DialogCategory": 8,
                        "DialogCondition": 0,
                        "GroupId": 5,
                        "ActionName": "",
                        "DialogType": 0,
                        "Duration": 11140,
                        "LocalizeKR": "형형색색의 꿈으로 가득한,\n마법의 길을!",
                        "LocalizeJP": "色とりどりの夢でいっぱいの、\n魔法の道を！",
                        "VoiceIds": [],
                        "CollectionVisible": false,
                        "CVCollectionType": 0,
                        "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle5",
                        "AnimationName": "Talk_05_M",
                        "Anniversary": 0,
                        "StartDate": "",
                        "EndDate": "",
                        "ApplyPosition": false,
                        "PosX": 0.0,
                        "PosY": 0.0,
                        "UnlockFavorRank": 0,
                        "UnlockEquipWeapon": false
                    }
                ],
