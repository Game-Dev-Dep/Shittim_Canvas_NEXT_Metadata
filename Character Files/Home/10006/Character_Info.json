            "DisplayOrder": 350,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 5,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 6000,
            "LocalizeKR": "제대로,\n끝까지 해 줘.",
            "LocalizeJP": "ちゃんと、\n最後までやって。",
            "VoiceIds": [],
