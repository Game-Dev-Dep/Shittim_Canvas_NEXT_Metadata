            "ActionName": "",
            "DialogType": 0,
            "Duration": 3450,
            "LocalizeKR": "으음, 맛있어~!",
            "LocalizeJP": "んんっ、美味しい～！",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle1",
            "AnimationName": "Talk_01_M",
            "Anniversary": 0,
