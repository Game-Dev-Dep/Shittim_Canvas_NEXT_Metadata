            "ActionName": "",
            "DialogType": 0,
            "Duration": 4400,
            "LocalizeKR": "늦지 않았네.\n선생님.",
            "LocalizeJP": "間に合ったね。先生。",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle1",
            "AnimationName": "Talk_01_M",
            "Anniversary": 0,
            "StartDate": "",
