            "DisplayOrder": 500,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 5,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 14170,
            "LocalizeKR": "이것이…… 내 신뢰의 증거다.",
