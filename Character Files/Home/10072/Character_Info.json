          },
          {
            "CharacterId": 10072,
            "CostumeUniqueId": 1007201,
            "DisplayOrder": 470,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 4,
            "ActionName": "",
            "DialogType": 1,
            "Duration": 3350,
            "LocalizeKR": "(…응? 어쩐지 호흡이\n어려워 보인다고?)",
            "LocalizeJP": "（…えっ？呼吸が\n苦しそうに見える？）",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle4",
            "AnimationName": "Talk_04_M",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
