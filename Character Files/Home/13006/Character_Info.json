  "Subtitles": {
    "Entries": [
      {
        "Region": 3,
        "CharacterDialogInfo_List": [
          {
            "CharacterId": 13006,
            "CostumeUniqueId": 1300601,
            "DisplayOrder": 270,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 1,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 9000,
            "LocalizeKR": "아아~ 아쉬워라.\n쿠흐흣, 결국 들켜버렸네~♪",
            "LocalizeJP": "あ～あ、ざーんねんっ。\nくふふっ、\nバレちゃったかぁ～♪",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle1",
            "AnimationName": "Talk_01_M",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 13006,
            "CostumeUniqueId": 1300601,
            "DisplayOrder": 280,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 2,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 8200,
            "LocalizeKR": "선생님. 오늘의 귀여운\n의뢰인은 다름 아닌,\n이 무츠키 쨩이었습니다~",
            "LocalizeJP": "何を隠そう、今日の可愛い\n依頼人の正体は他でもない、\nこのムツキちゃん\nなのでした～。",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle2",
            "AnimationName": "Talk_02_M",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 13006,
            "CostumeUniqueId": 1300601,
            "DisplayOrder": 290,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 2,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 10000,
            "LocalizeKR": "그도 그럴게,\n원래부터 흥신소의 의뢰를\n나 혼자 해결할 리가 없잖아~?",
            "LocalizeJP": "考えてもみてよ先生～。\nそもそも便利屋の依頼を、\n私一人で解決しに\n行くわけないじゃん？",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle2",
            "AnimationName": "",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 13006,
            "CostumeUniqueId": 1300601,
            "DisplayOrder": 300,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 3,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 6600,
            "LocalizeKR": "아핫, 어땠어? 선생님?\n그래도 내 장난~\n완벽하게 먹혀들었던 거지?",
            "LocalizeJP": "あはっ、どうだった？先生？\n私のいたずら、\nほぼ完璧だったでしょ？",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle3",
            "AnimationName": "Talk_03_M",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 13006,
            "CostumeUniqueId": 1300601,
            "DisplayOrder": 310,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 3,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 11000,
            "LocalizeKR": "꺄핫, 뭐야, 선생님의 얼빠진 얼굴,\n무지 웃겨. 아하핫~♪",
            "LocalizeJP": "きゃはっ、なぁに先生、\nその間抜けな顔。\nうける！あはは～っ♪",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle3",
            "AnimationName": "",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 13006,
            "CostumeUniqueId": 1300601,
            "DisplayOrder": 320,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 4,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 4600,
            "LocalizeKR": "오늘 선생님이랑\n여러가지를 했네.",
            "LocalizeJP": "今日は先生と、\nいろんなことしたねー。",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle4",
            "AnimationName": "Talk_04_M",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 13006,
            "CostumeUniqueId": 1300601,
            "DisplayOrder": 330,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 4,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 9000,
            "LocalizeKR": "크레이프도 먹고,\n유원지도 들렀고,\n아, 도서관에선\n공범이 되기까지…!",
            "LocalizeJP": "クレープ食べて、\n遊園地にも行って、\nあ、図書館では\n共犯にもなっちゃったし…！",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle4",
            "AnimationName": "",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 13006,
            "CostumeUniqueId": 1300601,
            "DisplayOrder": 340,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 5,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 6500,
            "LocalizeKR": "아아~ 마지막까지 완벽하게\n속일 수 있었는데. 아쉬워라~",
            "LocalizeJP": "あ～あ、最後まで完璧に\n騙せると思ったのに、\n残念だな～。",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle5",
            "AnimationName": "Talk_05_M",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 13006,
            "CostumeUniqueId": 1300601,
            "DisplayOrder": 350,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 5,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 8800,
            "LocalizeKR": "그래도 다음 번에는\n반드시 끝까지 속여줄 테니까.\n기대하라구~!",
            "LocalizeJP": "でも今度は、絶対に最後まで\n騙し通してみせるから、\n楽しみにしといてね～！",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle5",
            "AnimationName": "",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 13006,
            "CostumeUniqueId": 1300601,
            "DisplayOrder": 360,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 6,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 7500,
            "LocalizeKR": "아,\n오늘 엄청 재밌었다!",
            "LocalizeJP": "あーっ、今日はほんっと、\n楽しかった！",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle6",
            "AnimationName": "Talk_06_M",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          }
