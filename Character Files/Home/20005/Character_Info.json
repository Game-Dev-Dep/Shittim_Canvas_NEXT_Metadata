          },
          {
            "CharacterId": 20005,
            "CostumeUniqueId": 2000501,
            "DisplayOrder": 290,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 3,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 10200,
            "LocalizeKR": "아, 선생님.\n\r너무 가까이 계시면\n물줄기에 젖을지도 몰라요?",
            "LocalizeJP": "あ、先生。\nあまり近くにいると、\n水がかかってしまう\nかもしれませんよ？",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle3",
            "AnimationName": "Talk_03_M",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
