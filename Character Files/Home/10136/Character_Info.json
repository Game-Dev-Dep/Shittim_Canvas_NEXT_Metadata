          },
          {
            "CharacterId": 10136,
            "CostumeUniqueId": 1013601,
            "DisplayOrder": 490,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 2,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 6000,
            "LocalizeKR": "우리가 아는\n밤하늘과 비슷하면서도.",
            "LocalizeJP": "私たちの知っている\n夜空と似ているようで……。",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle2",
            "AnimationName": "Talk_02_M",
            "Anniversary": 0,
