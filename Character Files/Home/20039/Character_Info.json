    "Entries": [
      {
        "Region": 3,
        "CharacterDialogInfo_List": [
          {
            "CharacterId": 20039,
            "CostumeUniqueId": 2003901,
            "DisplayOrder": 330,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 1,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 7000,
            "LocalizeKR": "후후… 드디어 이쪽을\n바라보아 주는구나.",
            "LocalizeJP": "ふふ……ようやくこちらを\n見てくれたかの。",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle1",
            "AnimationName": "Talk_01_M",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 20039,
            "CostumeUniqueId": 2003901,
            "DisplayOrder": 340,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 1,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 11500,
            "LocalizeKR": "하지만 말이다, 선생.\n한 번 생각해 보는 것이\n어떨까.",
            "LocalizeJP": "じゃが、先生。\n一度考えてみてくれぬか？",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle1",
            "AnimationName": "",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 20039,
            "CostumeUniqueId": 2003901,
            "DisplayOrder": 350,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 2,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 6440,
            "LocalizeKR": "나는 이 순간 정말\n약해져 있는 것일 수도 있고…",
            "LocalizeJP": "妾は今、弱っているのかも\nしれぬが……",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle2",
            "AnimationName": "Talk_02_M",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 20039,
            "CostumeUniqueId": 2003901,
            "DisplayOrder": 360,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 2,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 9060,
            "LocalizeKR": "사실은 약해진 척하고\n있을 뿐인지도 모르지?",
            "LocalizeJP": "弱ったふりを\nしているだけかもしれぬ。",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle2",
            "AnimationName": "",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 20039,
            "CostumeUniqueId": 2003901,
            "DisplayOrder": 370,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 3,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 8530,
            "LocalizeKR": "혹은… 선생의 반응을\n떠 보고 있다거나.",
            "LocalizeJP": "あるいは……先生の出方を\n伺っているだけなのやも。",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle3",
            "AnimationName": "Talk_03_M",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 20039,
            "CostumeUniqueId": 2003901,
            "DisplayOrder": 380,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 3,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 12300,
            "LocalizeKR": "단지―그대를 깊이\n믿고 있는 것일수도 있다.",
            "LocalizeJP": "単に――其方を心から\n信じているだけかも\nしれぬしな？",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle3",
            "AnimationName": "",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 20039,
            "CostumeUniqueId": 2003901,
            "DisplayOrder": 390,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 4,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 12500,
            "LocalizeKR": "하지만… 그래, 이것만은\n약속할 수 있을 듯하구나.",
            "LocalizeJP": "だが……そうじゃな、\nこれだけは確約できる。",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle4",
            "AnimationName": "Talk_04_M",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 20039,
            "CostumeUniqueId": 2003901,
            "DisplayOrder": 400,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 5,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 4200,
            "LocalizeKR": "여기서 무슨 일이\n일어나더라도…",
            "LocalizeJP": "此処で何が起こったとて……",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle5",
            "AnimationName": "Talk_05_M",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 20039,
            "CostumeUniqueId": 2003901,
            "DisplayOrder": 410,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 5,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 13300,
            "LocalizeKR": "나는 그대를 탓하지\n않을 것이다.\n…영원히, 말이지.",
            "LocalizeJP": "妾が其方を責めることは\n無いじゃろう。……永劫にな。",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
