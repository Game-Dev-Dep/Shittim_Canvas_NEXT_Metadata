            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 10111,
            "CostumeUniqueId": 1011101,
            "DisplayOrder": 430,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 4,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 6310,
            "LocalizeKR": "평소처럼 하는 게\n더 좋은가?",
            "LocalizeJP": "普段みたいな方がいいか？",
