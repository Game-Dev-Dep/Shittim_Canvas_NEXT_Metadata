          },
          {
            "CharacterId": 10111,
            "CostumeUniqueId": 1011101,
            "DisplayOrder": 370,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 1,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 7100,
            "LocalizeKR": "응? 왜 그렇게 봐?",
            "LocalizeJP": "ん？どうかしたのか？",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle1",
            "AnimationName": "",
            "Anniversary": 0,
