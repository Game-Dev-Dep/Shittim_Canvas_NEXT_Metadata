            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 5,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 6850,
            "LocalizeKR": "아아~ 이 황금색 접시에\n담긴 초밥은 어떤 맛이 나려나~",
            "LocalizeJP": "あっ、この金のお皿に\n乗ったお寿司、\nきっと美味しいんでしょうね～。",
            "VoiceIds": [],
            "CollectionVisible": false,
