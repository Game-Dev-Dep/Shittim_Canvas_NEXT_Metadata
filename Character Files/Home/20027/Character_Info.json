            "DisplayOrder": 390,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 4,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 9850,
            "LocalizeKR": "으으응…\n그렇지 않아. 지금도,\n이걸 생각하게 된 계기도.",
            "LocalizeJP": "ううん…そんなことない。\n今も、これを考えるように\nなったきっかけも。",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle4",
            "AnimationName": "Talk_04_M",
