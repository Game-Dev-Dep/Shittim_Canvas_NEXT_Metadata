            "DisplayOrder": 400,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 4,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 5700,
            "LocalizeKR": "그 아니아니아니!\n그, 그게 아니라……!",
            "LocalizeJP": "って！いやいやいや！\nそ、そうじゃなくてですね！",
