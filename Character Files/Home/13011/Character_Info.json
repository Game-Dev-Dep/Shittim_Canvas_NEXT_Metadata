            "DisplayOrder": 310,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 4,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 11000,
            "LocalizeKR": "아하핫! 괜찮다니 다행이네~\n그래도 오늘- 선생님 덕분에\n엄청 재미있었어!",
            "LocalizeJP": "あはっ、大丈夫なら良かった。\n今日も先生のおかげで、\nすっごく楽しかったよ！",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle4",
            "AnimationName": "Talk_04_M",
            "Anniversary": 0,
