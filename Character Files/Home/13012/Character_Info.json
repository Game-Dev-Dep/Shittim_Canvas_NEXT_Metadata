            "Duration": 10000,
            "LocalizeKR": "(어, 어떻게 하죠…?\n으읏, 읏……!\n푸, 풀리지 않아……?!)",
            "LocalizeJP": "（ど、どうしましょう……！\nふんっ、んっ……！\nは、外れない……！）",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle1",
            "AnimationName": "Talk_01_M",
            "Anniversary": 0,
