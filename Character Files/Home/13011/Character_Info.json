            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 5,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 4050,
            "LocalizeKR": "다음에 또 이런\n이벤트가 있다면……",
            "LocalizeJP": "もしまたこういう\nイベントがあったら、",
            "VoiceIds": [],
            "CollectionVisible": false,
