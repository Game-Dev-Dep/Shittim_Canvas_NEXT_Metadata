          },
          {
            "CharacterId": 16005,
            "CostumeUniqueId": 1600501,
            "DisplayOrder": 360,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 5,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 5600,
            "LocalizeKR": "어, 어라……\n왜 그러십니까?",
            "LocalizeJP": "あ、あれ……\nど、どうかしましたか！？",
            "VoiceIds": [],
            "CollectionVisible": false,
