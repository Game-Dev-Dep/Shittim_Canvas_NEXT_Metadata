          },
          {
            "CharacterId": 10072,
            "CostumeUniqueId": 1007201,
            "DisplayOrder": 480,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 4,
            "ActionName": "",
            "DialogType": 1,
            "Duration": 9150,
            "LocalizeKR": "(아니야, 아무것도\n문제없어. 괜찮아!)",
            "LocalizeJP": "（いや、\n何も問題ない。\n大丈夫だ！）",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle4",
            "AnimationName": "",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
