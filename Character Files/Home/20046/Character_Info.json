            "DialogCondition": 0,
            "GroupId": 5,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 5210,
            "LocalizeKR": "네…… 진심으로\n반성하고 있으니까…….",
            "LocalizeJP": "ええ……心から\n反省しておりますので……",
            "VoiceIds": [],
