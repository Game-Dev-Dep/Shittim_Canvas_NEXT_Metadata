            "DisplayOrder": 490,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 5,
            "ActionName": "",
            "DialogType": 1,
            "Duration": 6350,
            "LocalizeKR": "(다만 평소와는 다르게…\n호흡이 조금 불안정하네.)",
            "LocalizeJP": "（なんだか、\nいつもと違って…\n呼吸が不安定だ）",
            "VoiceIds": [],
            "CollectionVisible": false,
