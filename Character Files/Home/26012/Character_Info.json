          },
          {
            "CharacterId": 26012,
            "CostumeUniqueId": 2601201,
            "DisplayOrder": 300,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 2,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 9010,
            "LocalizeKR": "심폐소생술은……\n필요 없을 것 같네요.",
            "LocalizeJP": "心肺蘇生法は……\n必要なさそうですね。",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle2",
            "AnimationName": "",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
