            "DisplayOrder": 340,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 4,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 3500,
            "LocalizeKR": "하이쿠를 지을 수\n있을 것 같아.",
            "LocalizeJP": "詠めそうな気がする。",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
