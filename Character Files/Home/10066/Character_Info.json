            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 2,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 4050,
            "LocalizeKR": "선생님께 보여드리려고\n생각했는데……",
