            "CostumeUniqueId": 1000201,
            "DisplayOrder": 360,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 3,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 10100,
            "LocalizeKR": "제일 좋아하는 사람과 함께\n제일 좋아하는 음식을 먹는다.\n이게 바로…",
            "LocalizeJP": "一番好きな御方と一緒に、\n一番好きな食べ物を頂く。\nこれぞ正しく…。",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle3",
            "AnimationName": "Talk_03_M",
            "Anniversary": 0,
            "StartDate": "",
