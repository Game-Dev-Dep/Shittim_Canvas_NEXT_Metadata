    "Entries": [
      {
        "Region": 3,
        "CharacterDialogInfo_List": [
          {
            "CharacterId": 16000,
            "CostumeUniqueId": 1600001,
            "DisplayOrder": 280,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 1,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 10000,
            "LocalizeKR": "아, 응? 에…!?\n어, 어어어, 어째서?\n으에!?",
            "LocalizeJP": "あ、えっ？えっ…！？\nな、なななんで、えっ！？",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle1",
            "AnimationName": "Talk_01_M",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 16000,
            "CostumeUniqueId": 1600001,
            "DisplayOrder": 290,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 2,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 9000,
            "LocalizeKR": "어, 어째서…!\n어째서 선생님께서\n여기 계시는지…!?",
            "LocalizeJP": "ど、どうして…！？\nどうして先生が、こ、ここに\nいらっしゃるのですか…！？",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle2",
            "AnimationName": "Talk_02_M",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 16000,
            "CostumeUniqueId": 1600001,
            "DisplayOrder": 300,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 2,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 5250,
            "LocalizeKR": "제, 제가 또\n이상한 실수를…!",
            "LocalizeJP": "わ、私また何か\nとんでもないミスを…！？",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle2",
            "AnimationName": "",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 16000,
            "CostumeUniqueId": 1600001,
            "DisplayOrder": 310,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 2,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 11250,
            "LocalizeKR": "아, 호, 혹시\n장소 전달을\n잘못 알고…?",
            "LocalizeJP": "あ、も、もしかして\n伝える場所を間違えて…！？",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle2",
            "AnimationName": "",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 16000,
            "CostumeUniqueId": 1600001,
            "DisplayOrder": 320,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 3,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 8900,
            "LocalizeKR": "아, 그, 그게 말이죠.\n여기는 그…\n뭐라고 해야 하나…",
            "LocalizeJP": "あ、え、えっとですね、\nここはその…\n何と言いますか…。",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle3",
            "AnimationName": "Talk_03_M",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 16000,
            "CostumeUniqueId": 1600001,
            "DisplayOrder": 330,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 3,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 13650,
            "LocalizeKR": "그, 제가 잡초라던가…\n그런 걸 키우는 장소입니다만…\n그게…",
            "LocalizeJP": "その、私が雑草とか…\nそういうのを\n育てている場所、でして…。",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle3",
            "AnimationName": "",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 16000,
            "CostumeUniqueId": 1600001,
            "DisplayOrder": 340,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 4,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 10650,
            "LocalizeKR": "죄, 죄송합니다, 선생님.\n제가 또 실수로…\n소중한 분을, 이런 곳에…",
            "LocalizeJP": "す、すみません先生、\nまた私のミスで…\n大切な方を、\nこんなところに…。",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle4",
            "AnimationName": "Talk_04_M",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 16000,
            "CostumeUniqueId": 1600001,
            "DisplayOrder": 350,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 4,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 13850,
            "LocalizeKR": "…어? 아…?\n저, 바, 방금 뭐,\n뭐뭐뭐 뭔가 또\n엄청난 소리를…!?",
            "LocalizeJP": "え、あ…\nわ、私もしかして今、\nな、ななな何か、\n凄いことを口に…っ！？",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle4",
            "AnimationName": "",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 16000,
            "CostumeUniqueId": 1600001,
            "DisplayOrder": 360,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 5,
            "ActionName": "",
            "DialogType": 1,
            "Duration": 12000,
            "LocalizeKR": "(죽고싶어죽고싶어죽고싶어\n죽고싶어죽고싶어죽고싶어\n죽고싶어죽고싶어…)",
            "LocalizeJP": "（しっ、\n死にたい死にたい死にたい\n死にたい死にたい死にたい\n死にたい死なないと…！）",
