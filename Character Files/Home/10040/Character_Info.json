            "ScriptKr": "#na;여자아이; 앗! 초코!",
            "TextJp": "あっ、チョコ！",
            "VoiceId": 0
          },
          {
            "ByteBuffer": {
              "Position": 0,
              "Length": 104
            },
            "GroupId": 1004006,
            "SelectionGroup": 0,
