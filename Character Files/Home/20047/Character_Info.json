                        "UnlockFavorRank": 0,
                        "UnlockEquipWeapon": false
                    },
                    {
                        "CharacterId": 20047,
                        "CostumeUniqueId": 2004701,
                        "DisplayOrder": 500,
                        "DialogCategory": 8,
                        "DialogCondition": 0,
                        "GroupId": 1,
                        "ActionName": "",
                        "DialogType": 0,
                        "Duration": 8980,
                        "LocalizeKR": "마음껏\n즐겨줬으면 좋겠어.",
                        "LocalizeJP": "ほら、\n存分に楽しんで。",
                        "VoiceIds": [],
                        "CollectionVisible": false,
                        "CVCollectionType": 0,
                        "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle1",
                        "AnimationName": "",
                        "Anniversary": 0,
                        "StartDate": "",
                        "EndDate": "",
                        "ApplyPosition": false,
                        "PosX": 0.0,
                        "PosY": 0.0,
                        "UnlockFavorRank": 0,
                        "UnlockEquipWeapon": false
                    },
                    {
                        "CharacterId": 20047,
                        "CostumeUniqueId": 2004701,
                        "DisplayOrder": 510,
                        "DialogCategory": 8,
                        "DialogCondition": 0,
                        "GroupId": 2,
                        "ActionName": "",
                        "DialogType": 0,
                        "Duration": 6380,
                        "LocalizeKR": "사실……\n처음이야.",
                        "LocalizeJP": "実は……全部、\n初めてなんだ。",
                        "VoiceIds": [],
                        "CollectionVisible": false,
                        "CVCollectionType": 0,
                        "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle2",
                        "AnimationName": "Talk_02_M",
                        "Anniversary": 0,
                        "StartDate": "",
                        "EndDate": "",
                        "ApplyPosition": false,
                        "PosX": 0.0,
                        "PosY": 0.0,
                        "UnlockFavorRank": 0,
                        "UnlockEquipWeapon": false
                    },
                    {
                        "CharacterId": 20047,
                        "CostumeUniqueId": 2004701,
                        "DisplayOrder": 520,
                        "DialogCategory": 8,
                        "DialogCondition": 0,
                        "GroupId": 2,
                        "ActionName": "",
                        "DialogType": 0,
                        "Duration": 5930,
                        "LocalizeKR": "뭔가를 만들며\n그 사람의 얼굴이\n계속 떠오른 것도.",
                        "LocalizeJP": "何かを作っているとき、\n誰かの顔が\nずっと浮かぶのも。",
                        "VoiceIds": [],
                        "CollectionVisible": false,
                        "CVCollectionType": 0,
                        "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle2",
                        "AnimationName": "",
                        "Anniversary": 0,
                        "StartDate": "",
                        "EndDate": "",
                        "ApplyPosition": false,
                        "PosX": 0.0,
                        "PosY": 0.0,
                        "UnlockFavorRank": 0,
                        "UnlockEquipWeapon": false
                    },
                    {
                        "CharacterId": 20047,
                        "CostumeUniqueId": 2004701,
                        "DisplayOrder": 530,
                        "DialogCategory": 8,
                        "DialogCondition": 0,
                        "GroupId": 2,
                        "ActionName": "",
                        "DialogType": 0,
                        "Duration": 9360,
                        "LocalizeKR": "이렇게 무방비한 모습을\n다른 사람에게 보이는 것도.",
                        "LocalizeJP": "無防備な姿を、\n誰かに見せるのも。",
                        "VoiceIds": [],
                        "CollectionVisible": false,
                        "CVCollectionType": 0,
                        "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle2",
                        "AnimationName": "",
                        "Anniversary": 0,
                        "StartDate": "",
                        "EndDate": "",
                        "ApplyPosition": false,
                        "PosX": 0.0,
                        "PosY": 0.0,
                        "UnlockFavorRank": 0,
                        "UnlockEquipWeapon": false
                    },
                    {
                        "CharacterId": 20047,
                        "CostumeUniqueId": 2004701,
                        "DisplayOrder": 540,
                        "DialogCategory": 8,
                        "DialogCondition": 0,
                        "GroupId": 3,
                        "ActionName": "",
                        "DialogType": 0,
                        "Duration": 9330,
                        "LocalizeKR": "딱히…… 누구라고까지는\n말하지는 않겠지만.",
                        "LocalizeJP": "別に……誰とまでは\n言わないけど。",
                        "VoiceIds": [],
                        "CollectionVisible": false,
                        "CVCollectionType": 0,
                        "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle3",
                        "AnimationName": "Talk_03_M",
                        "Anniversary": 0,
                        "StartDate": "",
                        "EndDate": "",
                        "ApplyPosition": false,
                        "PosX": 0.0,
                        "PosY": 0.0,
                        "UnlockFavorRank": 0,
                        "UnlockEquipWeapon": false
                    },
                    {
                        "CharacterId": 20047,
                        "CostumeUniqueId": 2004701,
                        "DisplayOrder": 550,
                        "DialogCategory": 8,
                        "DialogCondition": 0,
                        "GroupId": 4,
                        "ActionName": "",
                        "DialogType": 0,
                        "Duration": 4740,
                        "LocalizeKR": "……앞으로도 내 곁에 있어 줘.",
                        "LocalizeJP": "……これからも\n私のそばにいて。",
                        "VoiceIds": [],
                        "CollectionVisible": false,
                        "CVCollectionType": 0,
                        "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle4",
                        "AnimationName": "Talk_04_M",
                        "Anniversary": 0,
                        "StartDate": "",
                        "EndDate": "",
                        "ApplyPosition": false,
                        "PosX": 0.0,
                        "PosY": 0.0,
                        "UnlockFavorRank": 0,
                        "UnlockEquipWeapon": false
                    },
                    {
                        "CharacterId": 20047,
                        "CostumeUniqueId": 2004701,
                        "DisplayOrder": 560,
                        "DialogCategory": 8,
                        "DialogCondition": 0,
                        "GroupId": 4,
                        "ActionName": "",
                        "DialogType": 0,
                        "Duration": 9590,
                        "LocalizeKR": "나도 항상 당신의 곁을\n지킬 테니까.",
                        "LocalizeJP": "あんたの隣は、\n私が守るから。",
                        "VoiceIds": [],
                        "CollectionVisible": false,
                        "CVCollectionType": 0,
                        "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle4",
                        "AnimationName": "",
                        "Anniversary": 0,
                        "StartDate": "",
                        "EndDate": "",
                        "ApplyPosition": false,
