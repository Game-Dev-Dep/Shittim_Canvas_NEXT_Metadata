  "Subtitles": {
    "Entries": [
      {
        "Region": 3,
        "CharacterDialogInfo_List": [
          {
            "CharacterId": 23003,
            "CostumeUniqueId": 2300301,
            "DisplayOrder": 290,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 1,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 6050,
            "LocalizeKR": "하아……\n갑자기 소나기라니.",
            "LocalizeJP": "ふう…\n急に夕立だなんて。",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle1",
            "AnimationName": "Talk_01_M",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 23003,
            "CostumeUniqueId": 2300301,
            "DisplayOrder": 300,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 1,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 10000,
            "LocalizeKR": "요새는 일기예보도\n완전히 신뢰하기가 어렵다니까.",
            "LocalizeJP": "最近は、天気予報も\n信頼できなくて困るね。",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle1",
            "AnimationName": "",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 23003,
            "CostumeUniqueId": 2300301,
            "DisplayOrder": 310,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 2,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 7250,
            "LocalizeKR": "그럼, 지금부터 무얼 할까?",
            "LocalizeJP": "さて…\nこの後、何をしようか？",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle2",
            "AnimationName": "Talk_02_M",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 23003,
            "CostumeUniqueId": 2300301,
            "DisplayOrder": 320,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 2,
            "ActionName": "",
            "DialogType": 1,
            "Duration": 13250,
            "LocalizeKR": "(아니… 방금 그 말은\n이상한 소리처럼 들렸으려나?)",
            "LocalizeJP": "（ん…今の言葉、もしかして\n変な意味に聞こえたかな？）",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle2",
            "AnimationName": "",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 23003,
            "CostumeUniqueId": 2300301,
            "DisplayOrder": 330,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 3,
            "ActionName": "",
            "DialogType": 1,
            "Duration": 15000,
            "LocalizeKR": "(하지만 넷카페는 나도 처음이고,\n다른 사람들은 이런 곳에서\n무얼 하는지도 모르니…)",
            "LocalizeJP": "（でも、ネットカフェなんて\n私も初めてだし、\n普通こういう所で\n何をするものなのか\nも知らないし…）",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle3",
            "AnimationName": "Talk_03_M",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 23003,
            "CostumeUniqueId": 2300301,
            "DisplayOrder": 340,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 3,
            "ActionName": "",
            "DialogType": 1,
            "Duration": 15000,
            "LocalizeKR": "(게다가 이 공간은 너무 좁아서…\n선생님의 얼굴이 가까워…)",
            "LocalizeJP": "（というかこの空間、\n狭くて…\n先生の顔が近い…っ）",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle3",
            "AnimationName": "",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 23003,
            "CostumeUniqueId": 2300301,
            "DisplayOrder": 350,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 4,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 9250,
            "LocalizeKR": "머, 먼저 씻고 오겠다고?\n잠깐, 무슨 생각을 하는 거야?!",
            "LocalizeJP": "え、さ、先にシャワーを\n浴びてくるって？\nちょっと、なっ、どうして？！",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle4",
            "AnimationName": "Talk_04_M",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 23003,
            "CostumeUniqueId": 2300301,
            "DisplayOrder": 360,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 4,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 12850,
            "LocalizeKR": "아. 비에 젖은 머리를 씻고 온다고?\n……미안, 아니, 신경쓰지마.",
            "LocalizeJP": "あ、雨に濡れたから、\n髪を洗いに？…ごめん、\nいや、気にしないで。",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle4",
            "AnimationName": "",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 23003,
            "CostumeUniqueId": 2300301,
            "DisplayOrder": 370,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 4,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 8500,
            "LocalizeKR": "넷카페에는\n샤워시설도 있는 건가.",
            "LocalizeJP": "ネットカフェには、\nシャワーの設備もあるんだね。",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle4",
            "AnimationName": "",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 23003,
            "CostumeUniqueId": 2300301,
            "DisplayOrder": 380,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 5,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 9500,
            "LocalizeKR": "이것 봐, 선생님.\n드링크 바는 무료래.\n에너지 드링크도 있으려나?",
            "LocalizeJP": "あ、見て、先生。\nドリンクバーが無料だって。\nエナジードリンクもあるかな？",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle5",
            "AnimationName": "Talk_05_M",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 23003,
            "CostumeUniqueId": 2300301,
            "DisplayOrder": 390,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 5,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 18750,
            "LocalizeKR": "인터넷도 자유롭게 쓸 수 있는데,\n드링크도 무료라니.\n굉장하네, 완전히 나 같은\n사람들을 위한 공간이잖아?",
            "LocalizeJP": "ネットも自由に使えるし、\nドリンクも無料だし。\nこれは素晴らしい、\n完全に私のような\n人間のための空間。",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle5",
            "AnimationName": "",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 23003,
            "CostumeUniqueId": 2300301,
            "DisplayOrder": 400,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 6,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 6800,
            "LocalizeKR": "여기서라면 언제까지고\n계속 머무를 수 있겠어.",
            "LocalizeJP": "ここになら、\nいつまででもずっと\nいられそうだね？",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle6",
            "AnimationName": "Talk_06_M",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 23003,
            "CostumeUniqueId": 2300301,
            "DisplayOrder": 410,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 6,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 13750,
            "LocalizeKR": "그러니까… 이상한 의미로\n한 말이 아니니까.\n오해하지 말아줘…",
            "LocalizeJP": "あ、えっと…今のも、\n別に変な意味ではないから。\n誤解しないでね…。",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle6",
            "AnimationName": "",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          }
        ],
