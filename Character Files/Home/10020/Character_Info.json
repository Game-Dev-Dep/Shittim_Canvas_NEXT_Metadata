            "GroupId": 4,
            "ActionName": "",
            "DialogType": 1,
            "Duration": 6750,
            "LocalizeKR": "(서, 설마?! 그런 짓까지도……!?)",
            "LocalizeJP": "（っ！？ま、まさか、\nそんなことまで……！？）",
