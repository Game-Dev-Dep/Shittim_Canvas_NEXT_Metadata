            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 4,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 7400,
            "LocalizeKR": "…선생님과 함께라면,\n앞으로도 얼마든지-",
            "LocalizeJP": "…先生と一緒なら、\nまだまだいくつでも、",
            "VoiceIds": [],
            "CollectionVisible": false,
