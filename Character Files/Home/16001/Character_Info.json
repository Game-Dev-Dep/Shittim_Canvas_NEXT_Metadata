          },
          {
            "CharacterId": 16001,
            "CostumeUniqueId": 1600101,
            "DisplayOrder": 310,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 4,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 6600,
            "LocalizeKR": "후후. 역시 이렇게\n주인님 곁에 있으니,\n두근두근한걸-.",
            "LocalizeJP": "ふふっ。\nやっぱりこうしてご主人様の\nそばにいると、心が躍るなー。",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle4",
            "AnimationName": "Talk_04_M",
            "Anniversary": 0,
            "StartDate": "",
