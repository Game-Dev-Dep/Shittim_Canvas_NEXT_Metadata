            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 13012,
            "CostumeUniqueId": 1301201,
            "DisplayOrder": 230,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 2,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 10000,
            "LocalizeKR": "…네? 아뇨, 아뇨!\n다른 것도 아니고 경찰인 본관이\n열쇠를 잃어버릴 리가 없잖습니까!",
            "LocalizeJP": "……え？い、いやいや！\n仮にも警察に属する本官が、\n鍵を失くすわけが\nないではありませんか！",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle2",
            "AnimationName": "Talk_02_M",
            "Anniversary": 0,
