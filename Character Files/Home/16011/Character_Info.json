            "GroupId": 4,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 9400,
            "LocalizeKR": "어째서\n1년 사이에 이런…",
            "LocalizeJP": "どうして…\n一年の間にこのような…。",
