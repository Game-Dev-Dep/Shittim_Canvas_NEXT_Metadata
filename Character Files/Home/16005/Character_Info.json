            "DialogType": 0,
            "Duration": 4700,
            "LocalizeKR": "카하하하하하-",
            "LocalizeJP": "きひっ、\nきゃははははははっ！",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle1",
            "AnimationName": "Talk_01_M",
            "Anniversary": 0,
            "StartDate": "",
