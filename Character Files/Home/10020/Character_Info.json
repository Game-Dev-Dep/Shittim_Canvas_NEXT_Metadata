            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 10020,
            "CostumeUniqueId": 1002001,
            "DisplayOrder": 320,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 3,
            "ActionName": "",
            "DialogType": 1,
            "Duration": 11800,
            "LocalizeKR": "(이, 이 전개라면……\n그 책에서 몇 번이나 봤었어……\n저, 정말 그 흐름이야?!)",
            "LocalizeJP": "（こ、こういう展開、\n本で何度も見たことある……！\n本当に、本当にあの\n流れに入っちゃうの！？）",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle3",
            "AnimationName": "Talk_03_M",
