            "DisplayOrder": 540,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 4,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 4200,
            "LocalizeKR": "그런데 어째서일까.",
