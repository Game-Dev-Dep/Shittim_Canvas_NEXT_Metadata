            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 2,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 4130,
            "LocalizeKR": "아, 방금은……",
            "LocalizeJP": "ああ、これが……",
