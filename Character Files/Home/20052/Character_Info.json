          },
          {
            "CharacterId": 20052,
            "CostumeUniqueId": 2005201,
            "DisplayOrder": 600,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 2,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 8450,
            "LocalizeKR": "그렇게 말하자마자\n추워졌습니다.",
            "LocalizeJP": "……と思いましたが、\n寒いですねやっぱ。",
            "VoiceIds": [],
