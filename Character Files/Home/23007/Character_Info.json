            "DisplayOrder": 350,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 3,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 7000,
            "LocalizeKR": "여기서 같이 벗어 보실까요?",
            "LocalizeJP": "ここで一緒に、\n脱いでしまいません……？",
            "VoiceIds": [],
            "CollectionVisible": false,
