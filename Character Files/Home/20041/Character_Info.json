            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 5,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 3780,
            "LocalizeKR": "……알았어.",
            "LocalizeJP": "……分かったわ。",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle5",
            "AnimationName": "Talk_05_M",
            "Anniversary": 0,
