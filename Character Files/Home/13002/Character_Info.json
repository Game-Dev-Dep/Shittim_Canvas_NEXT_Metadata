            "DisplayOrder": 390,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 4,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 8000,
            "LocalizeKR": "아까 전부터 선생님의\n이마에서 식은땀이\n흘러내리고 있는데요?",
            "LocalizeJP": "先程から先生の額に、\n冷や汗が流れてません？",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle4",
            "AnimationName": "",
            "Anniversary": 0,
