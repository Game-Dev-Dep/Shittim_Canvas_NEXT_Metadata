            "DisplayOrder": 360,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 2,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 5550,
            "LocalizeKR": "……왜 그래?\n그런 얼굴 하고.",
            "LocalizeJP": "…どうしたの？\nそんな顔して。",
            "VoiceIds": [],
            "CollectionVisible": false,
