          },
          {
            "CharacterId": 10021,
            "CostumeUniqueId": 1002101,
            "DisplayOrder": 400,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 3,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 7600,
            "LocalizeKR": "사실 이렇게 탁 트인 위치는\n별로 좋아하지 않았어.",
            "LocalizeJP": "元々、こういう開けた\n場所はあまり\n好きじゃなかった。",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle3",
            "AnimationName": "Talk_03_M",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 10021,
            "CostumeUniqueId": 1002101,
            "DisplayOrder": 410,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 3,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 7500,
            "LocalizeKR": "숨을 곳도 없고……\n주변 경계도 힘들고……",
            "LocalizeJP": "隠れる場所も無いし、\n周囲の警戒も大変で……",
