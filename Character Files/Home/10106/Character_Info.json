            "DisplayOrder": 340,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 3,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 5200,
            "LocalizeKR": "자매님들과 선생님께서……?",
            "LocalizeJP": "シスターの皆様と、\n先生が……？",
            "VoiceIds": [],
            "CollectionVisible": false,
