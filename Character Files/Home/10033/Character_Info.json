  "Subtitles": {
    "Entries": [
      {
        "Region": 3,
        "CharacterDialogInfo_List": [
          {
            "CharacterId": 10033,
            "CostumeUniqueId": 1003301,
            "DisplayOrder": 600,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 1,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 11500,
            "LocalizeKR": "기뻐요…… 이 와카모,\n모든 것은 이렇게\n당신과 만나기 위해서……!",
            "LocalizeJP": "嬉しいです……！\nこのワカモ、全てはこうして\nあなた様と会うためだけに……！",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle1",
            "AnimationName": "Talk_01_M",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 10033,
            "CostumeUniqueId": 1003301,
            "DisplayOrder": 610,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 2,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 10500,
            "LocalizeKR": "어떻게든 직접,\n제 기분을, 이 감정을,\n전해드리고 싶어서……",
            "LocalizeJP": "どうにか直接、\nこの気持ちを、この想いを、\nお伝えしたくって……",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle2",
            "AnimationName": "Talk_02_M",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 10033,
            "CostumeUniqueId": 1003301,
            "DisplayOrder": 620,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 3,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 10500,
            "LocalizeKR": "이렇게 만나게 된 것 또한 분명,\n붉은 실로 맺어진 운명의 인도겠죠……",
            "LocalizeJP": "こうしてお会いできたのも\nきっと、赤い糸で結ばれた\n運命のお導き……。",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle3",
            "AnimationName": "Talk_03_M",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 10033,
            "CostumeUniqueId": 1003301,
            "DisplayOrder": 630,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 4,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 6400,
            "LocalizeKR": "아아…… 그, 그렇게\n뚫어져라 쳐다보시면……",
            "LocalizeJP": "あ、あぁ…… そ、そんなに\n見つめられては……！",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle4",
            "AnimationName": "Talk_04_M",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 10033,
            "CostumeUniqueId": 1003301,
            "DisplayOrder": 640,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 4,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 5500,
            "LocalizeKR": "아무리 저라고 해도,\n부끄러워져 버리고 말아요……",
            "LocalizeJP": "いくら私といえども、\n恥ずかしく\nなってしまいます……。",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle4",
            "AnimationName": "",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 10033,
            "CostumeUniqueId": 1003301,
            "DisplayOrder": 650,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 4,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 12000,
            "LocalizeKR": "당신의 그런 시선만으로도,\n몸 이곳저곳에서,\n안타까움이 흘러 넘쳐서……",
            "LocalizeJP": "あなた様のその視線だけで、\n身体のあちこちから、\nもどかしさが溢れ出して……っ。",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle4",
            "AnimationName": "",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 10033,
            "CostumeUniqueId": 1003301,
            "DisplayOrder": 660,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 5,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 9000,
            "LocalizeKR": "하지만…… 당신이\n그렇게나 원하신다면……\n네♡",
            "LocalizeJP": "ですが…… あなた様が\nそうお望みなのであれば……\nはい♡",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle5",
            "AnimationName": "Talk_05_M",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 10033,
            "CostumeUniqueId": 1003301,
            "DisplayOrder": 670,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 5,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 14300,
            "LocalizeKR": "자아, 부디 이쪽으로,\n좀 더 좀 더 저의 곁으로……\n우후후♡",
            "LocalizeJP": "さあ、どうぞこちらへ。\nもっともっと、私のお傍に……\nうふふふふっ♡",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle5",
            "AnimationName": "",
            "Anniversary": 0,
