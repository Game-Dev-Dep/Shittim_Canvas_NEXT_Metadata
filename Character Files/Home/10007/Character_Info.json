          },
          {
            "CharacterId": 10007,
            "CostumeUniqueId": 1000701,
            "DisplayOrder": 340,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 3,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 5500,
            "LocalizeKR": "선생님은 뭘 그린 거야?\n으음…",
            "LocalizeJP": "先生は何を描いたの？\nえーっと…。",
            "VoiceIds": [],
            "CollectionVisible": false,
