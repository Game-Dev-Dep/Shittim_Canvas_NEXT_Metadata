          },
          {
            "CharacterId": 16012,
            "CostumeUniqueId": 1601201,
            "DisplayOrder": 330,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 2,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 10500,
            "LocalizeKR": "왜 그렇게 놀라는거야!\n어, 어쩌다 많이 들어가\n있던 것뿐이야!",
            "LocalizeJP": "って、なんでそんなに驚くの！\nた、たまたま多く入ってたの！",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle2",
            "AnimationName": "Talk_02_M",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 16012,
            "CostumeUniqueId": 1601201,
            "DisplayOrder": 340,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 3,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 12500,
            "LocalizeKR": "이거, 선생님이\n사준 거기도 하고…\n거기에 오늘 하루 종일…",
            "LocalizeJP": "というかこれ、先生が\n買ってくれたものだし……。\nそれに、今日は一日中……。",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle3",
            "AnimationName": "Talk_03_M",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 16012,
            "CostumeUniqueId": 1601201,
            "DisplayOrder": 350,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 4,
            "ActionName": "",
            "DialogType": 1,
            "Duration": 4250,
            "LocalizeKR": "(생각해 보면, 오늘은\n하루 종일 선생님과……)",
            "LocalizeJP": "(そういえば、今日は\nずっと先生と……)",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle4",
            "AnimationName": "Talk_04_M",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 16012,
            "CostumeUniqueId": 1601201,
            "DisplayOrder": 360,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 4,
            "ActionName": "",
            "DialogType": 1,
            "Duration": 9927,
            "LocalizeKR": "(나, 난 대체, 뭘\n생각하고 있는 거야!)",
            "LocalizeJP": "(わ、私ってば、\n何を考えてるの！)",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle4",
            "AnimationName": "",
            "Anniversary": 0,
