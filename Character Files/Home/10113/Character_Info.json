            "DialogCondition": 0,
            "GroupId": 5,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 7860,
            "LocalizeKR": "……이 물은 정말로 차갑군요.",
            "LocalizeJP": "……この水は本当に、\n冷たいです。",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle5",
            "AnimationName": "Talk_05_M",
