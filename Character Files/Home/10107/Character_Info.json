            "GroupId": 5,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 12600,
            "LocalizeKR": "죄, 죄송합니다~!\n나가게 해주세요~!",
            "LocalizeJP": "ご、ごめんなさ～い！\n出してください～！",
