            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 5,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 6060,
            "LocalizeKR": "앗! 먹고 나면,\n양치하는 거 잊지 마!",
            "LocalizeJP": "あっ！食べたあとは、\n歯みがきを忘れないでね！",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle5",
            "AnimationName": "",
            "Anniversary": 0,
