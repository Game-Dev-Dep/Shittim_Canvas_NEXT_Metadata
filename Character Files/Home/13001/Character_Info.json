            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 4,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 8600,
            "LocalizeKR": "다음에도, 또 같이 하자?",
            "LocalizeJP": "次もまた、\n付き合ってくれる？",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
