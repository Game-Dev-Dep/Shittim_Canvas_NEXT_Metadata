            "DialogCondition": 0,
            "GroupId": 5,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 3280,
            "LocalizeKR": "그렇다면 끝까지 받도록 할게.",
            "LocalizeJP": "最後まで受け止めましょう。",
            "VoiceIds": [],
            "CollectionVisible": false,
