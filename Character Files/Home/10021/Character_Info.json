            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 10021,
            "CostumeUniqueId": 1002101,
            "DisplayOrder": 380,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 2,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 9200,
            "LocalizeKR": "이렇게 방해받지 않고,\n전부 내다볼 수 있는\n장소가 있었다니……",
            "LocalizeJP": "何にも邪魔されずに、\nこうして何もかもを\n見渡せる場所が\nあったなんて……。",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle2",
            "AnimationName": "Talk_02_M",
            "Anniversary": 0,
            "StartDate": "",
