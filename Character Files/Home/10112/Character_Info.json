            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 3,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 6150,
            "LocalizeKR": "……어라?\n아, 아아! 그러네!?",
