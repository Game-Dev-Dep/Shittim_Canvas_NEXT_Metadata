            "DisplayOrder": 390,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 5,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 8100,
            "LocalizeKR": "새해 복 많이 받아, 선생.",
            "LocalizeJP": "あけましておめでとう、\n先生。",
            "VoiceIds": [],
