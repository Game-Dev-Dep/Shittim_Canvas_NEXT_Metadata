            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 5,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 5600,
            "LocalizeKR": "뭐야, 선생님?\n왜 그런 눈으로\n날 보는 거지?",
            "LocalizeJP": "なんだ、先生？\n何故そんな目で私を見る？",
            "VoiceIds": [],
            "CollectionVisible": false,
