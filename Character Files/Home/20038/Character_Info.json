            "DisplayOrder": 380,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 4,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 10670,
            "LocalizeKR": "어머나? 그다지 재미있지\n않을 수도 있을 텐데요?",
            "LocalizeJP": "あら？あまり面白いものでは\nないかもしれませんよ？",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle4",
            "AnimationName": "Talk_04_M",
