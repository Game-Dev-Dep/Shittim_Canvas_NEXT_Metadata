            "DisplayOrder": 280,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 2,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 5450,
            "LocalizeKR": "음. 뭘까나~ 이 느낌…",
            "LocalizeJP": "うーん、\n何なんだろうなー、\nこの感じ…",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle2",
            "AnimationName": "Talk_02_M",
            "Anniversary": 0,
