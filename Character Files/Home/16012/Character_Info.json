          },
          {
            "CharacterId": 16012,
            "CostumeUniqueId": 1601201,
            "DisplayOrder": 370,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 5,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 8117,
            "LocalizeKR": "정말!\n내가 주겠다고 했으니까\n아무래도 좋잖아!",
            "LocalizeJP": "もう！私があげるって\n言ってるんだからいいじゃない！",
