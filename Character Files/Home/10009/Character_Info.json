          },
          {
            "CharacterId": 10009,
            "CostumeUniqueId": 1000901,
            "DisplayOrder": 460,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 5,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 9650,
            "LocalizeKR": "하지만, 이미\n먹어버린 건\n어쩔 수 없지……?",
            "LocalizeJP": "でも、\nもう食べちゃったものは\n仕方ないよね…？",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle5",
            "AnimationName": "",
            "Anniversary": 0,
