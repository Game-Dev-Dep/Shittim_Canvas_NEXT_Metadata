            "DisplayOrder": 520,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 1,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 6950,
            "LocalizeKR": "큰일이 나버린다구요…!",
            "LocalizeJP": "大変なことに\nなってしまいます…！",
            "VoiceIds": [],
            "CollectionVisible": false,
