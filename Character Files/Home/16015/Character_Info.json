            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 4,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 6200,
            "LocalizeKR": "……후후후.\n네! 좋아요!",
            "LocalizeJP": "……ふふふ。\nはい！どうぞ。",
            "VoiceIds": [],
            "CollectionVisible": false,
