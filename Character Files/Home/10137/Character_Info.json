          },
          {
            "CharacterId": 10137,
            "CostumeUniqueId": 1013701,
            "DisplayOrder": 510,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 5,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 2260,
            "LocalizeKR": "……앗 아뇨, 그!",
            "LocalizeJP": "……あっ、いや、その！",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle5",
            "AnimationName": "",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 10137,
            "CostumeUniqueId": 1013701,
            "DisplayOrder": 520,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 5,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 6250,
            "LocalizeKR": "이렇게 비 피할 곳도 있어서\n럭키-! 그래서 행복하구나-\n라는 의미에서!",
            "LocalizeJP": "こうやって雨宿りもできて、\nラッキーで幸せだなって意味で！",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle5",
            "AnimationName": "",
            "Anniversary": 0,
