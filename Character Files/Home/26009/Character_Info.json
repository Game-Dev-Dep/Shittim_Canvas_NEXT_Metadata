          },
          {
            "CharacterId": 26009,
            "CostumeUniqueId": 2600901,
            "DisplayOrder": 470,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 5,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 4650,
            "LocalizeKR": "히얏……?!\n자, 잠깐만 기다려 주세요!",
            "LocalizeJP": "ひゃっ！？\nちょ、ちょっと待ってください！",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle5",
            "AnimationName": "Talk_05_M",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 26009,
            "CostumeUniqueId": 2600901,
            "DisplayOrder": 480,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 5,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 13350,
            "LocalizeKR": "나갈게요!\n지, 지금 나갈 테니까……\n간지러워요!",
            "LocalizeJP": "出ます！\nい、今出ますから……\nくすぐったい！",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
