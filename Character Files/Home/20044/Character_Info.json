            "DisplayOrder": 420,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 1,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 9950,
            "LocalizeKR": "자, 드십시오.\n제가 준비한 것입니다.",
            "LocalizeJP": "どうぞ、お飲み物を\nご用意しています。",
            "VoiceIds": [],
            "CollectionVisible": false,
