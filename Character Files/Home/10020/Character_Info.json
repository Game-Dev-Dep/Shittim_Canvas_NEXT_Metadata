            "DisplayOrder": 330,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 4,
            "ActionName": "",
            "DialogType": 1,
            "Duration": 5600,
            "LocalizeKR": "(이런 거……라든가,\n저런 거……라든가……)",
            "LocalizeJP": "（あ、あんなこととか、\nこんなこと、とか……）",
