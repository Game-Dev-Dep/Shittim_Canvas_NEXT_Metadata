        "Region": 3,
        "CharacterDialogInfo_List": [
          {
            "CharacterId": 10134,
            "CostumeUniqueId": 1013401,
            "DisplayOrder": 580,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 1,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 6590,
            "LocalizeKR": "에헤헤.\n선생님, 놀랐습니까?",
            "LocalizeJP": "えへへ。\n先生、驚きましたか？",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle1",
            "AnimationName": "Talk_01_M",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 10134,
            "CostumeUniqueId": 1013401,
            "DisplayOrder": 590,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 1,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 12910,
            "LocalizeKR": "그저 선생님과 함께,\n이 밤하늘을 보고 싶어서\n불러 봤습니다.",
            "LocalizeJP": "先生と一緒に、\nこの夜空を見たくて……\n呼んだんです。",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle1",
            "AnimationName": "",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 10134,
            "CostumeUniqueId": 1013401,
            "DisplayOrder": 600,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 2,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 7530,
            "LocalizeKR": "정말 예쁘지\n않습니까?",
            "LocalizeJP": "とても……\n綺麗ですね。",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle2",
            "AnimationName": "Talk_02_M",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 10134,
            "CostumeUniqueId": 1013401,
            "DisplayOrder": 610,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 2,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 5390,
            "LocalizeKR": "아리스의 세계에는, 그리고 아직\n가보지 못한 세계에도……",
            "LocalizeJP": "アリスの世界にも、\nまだ行ったことのない\n世界にも……",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle2",
            "AnimationName": "",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 10134,
            "CostumeUniqueId": 1013401,
            "DisplayOrder": 620,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 2,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 11750,
            "LocalizeKR": "분명, 이런 아름다운 것들이\n잔뜩 있을 테지요.",
            "LocalizeJP": "きっとこんな綺麗なものが\nたくさんあると思うんです。",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle2",
            "AnimationName": "",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 10134,
            "CostumeUniqueId": 1013401,
            "DisplayOrder": 630,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 3,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 6380,
            "LocalizeKR": "하지만 이상합니다.",
            "LocalizeJP": "でも……不思議です。",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle3",
            "AnimationName": "Talk_03_M",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 10134,
            "CostumeUniqueId": 1013401,
            "DisplayOrder": 640,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 3,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 15960,
            "LocalizeKR": "세상은 이토록\n아름다운데……\n사람들은 어째서\n싸우는 걸까요?",
            "LocalizeJP": "世界って、\nこんなに綺麗なのに……\nどうして人は争うんでしょう？",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle3",
            "AnimationName": "",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 10134,
            "CostumeUniqueId": 1013401,
            "DisplayOrder": 650,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 4,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 20340,
            "LocalizeKR": "저 밤하늘의 별처럼,\n이 세상에는 모두가\n나눠 가져도 괜찮을 만큼\n아름다운 것들로 넘쳐날 텐데.",
            "LocalizeJP": "あの星空みたいに、この世界は、\nみんなで分け合っても\n大丈夫なくらい美しいもので\nあふれているのに……。",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle4",
            "AnimationName": "Talk_04_M",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 10134,
            "CostumeUniqueId": 1013401,
            "DisplayOrder": 660,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 5,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 14500,
            "LocalizeKR": "……역시, 아리스는\n아직 잘 모르겠습니다.",
            "LocalizeJP": "……やっぱり、アリスには\nまだわかりません。",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle5",
            "AnimationName": "Talk_05_M",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          }
        ],
