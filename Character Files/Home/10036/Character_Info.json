            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 2,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 4900,
            "LocalizeKR": "별 일 아니라고만,\n생각하고 있었던 터라……",
