            "DisplayOrder": 390,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 5,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 11000,
            "LocalizeKR": "잊, 잊어주세요,\n지금 건 잊어주세요!\n선생님!!",
            "LocalizeJP": "わ、忘れてください、\n今のは忘れてください！\n先生！！",
