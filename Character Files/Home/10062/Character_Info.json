            "DisplayOrder": 440,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 2,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 2400,
            "LocalizeKR": "C&C라는 이름에 걸맞는,",
            "LocalizeJP": "C&Cの名に相応しい、",
