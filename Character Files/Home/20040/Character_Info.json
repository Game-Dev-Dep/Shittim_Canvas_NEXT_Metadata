            "GroupId": 3,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 2370,
            "LocalizeKR": "으응?",
            "LocalizeJP": "う、うん？",
            "VoiceIds": [],
            "CollectionVisible": false,
