            "DisplayOrder": 380,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 3,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 4970,
            "LocalizeKR": "그러니까, 여기는 지금……",
            "LocalizeJP": "だから、ここは今――",
            "VoiceIds": [],
            "CollectionVisible": false,
