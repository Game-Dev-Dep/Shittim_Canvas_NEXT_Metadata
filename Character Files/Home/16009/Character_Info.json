            "BGName": 0,
            "BGEffect": 0,
            "PopupFileName": "",
            "ScriptKr": "[ns] \"가능하겠냐……! 우선 여기, 양동이로……!\"",
            "TextJp": "[ns] \"ごめん、バケツしか無い！\"",
