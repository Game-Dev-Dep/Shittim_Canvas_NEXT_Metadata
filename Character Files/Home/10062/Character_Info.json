          },
          {
            "CharacterId": 10062,
            "CostumeUniqueId": 1006201,
            "DisplayOrder": 450,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 2,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 6500,
            "LocalizeKR": "그런 메이드가\n되기 위해서라도요.",
            "LocalizeJP": "そんな\nメイドになるためにも。",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle2",
            "AnimationName": "",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 10062,
            "CostumeUniqueId": 1006201,
            "DisplayOrder": 460,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 3,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 7000,
            "LocalizeKR": "그런…… 가요?\n특별한 일은 아니라고 생각합니다만.",
            "LocalizeJP": "そう……でしょうか。\n特別なことでは\nないと思いますが。",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle3",
            "AnimationName": "Talk_03_M",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
