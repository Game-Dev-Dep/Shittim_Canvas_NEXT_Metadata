          },
          {
            "CharacterId": 10020,
            "CostumeUniqueId": 1002001,
            "DisplayOrder": 310,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 2,
            "ActionName": "",
            "DialogType": 1,
            "Duration": 7500,
            "LocalizeKR": "(자, 잠깐만…… 이대로라면\n설마 선생님과……)",
            "LocalizeJP": "（待って、もしかしてこの\nままだと私、先生と……！？）",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle2",
            "AnimationName": "",
            "Anniversary": 0,
