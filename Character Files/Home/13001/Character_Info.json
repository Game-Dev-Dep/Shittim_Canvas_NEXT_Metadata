            "DisplayOrder": 300,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 3,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 3050,
            "LocalizeKR": "날 저물어도",
            "LocalizeJP": "日は暮れど",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle3",
            "AnimationName": "Talk_03_M",
            "Anniversary": 0,
