          {
            "CharacterId": 10007,
            "CostumeUniqueId": 1000701,
            "DisplayOrder": 350,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 3,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 6000,
            "LocalizeKR": "푸하하! 이게 뭐야,\n완전 웃겨!",
            "LocalizeJP": "あはは！なにこれ、\nめっちゃ面白い！",
