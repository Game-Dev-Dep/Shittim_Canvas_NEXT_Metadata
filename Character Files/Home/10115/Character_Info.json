          },
          {
            "CharacterId": 10115,
            "CostumeUniqueId": 1011501,
            "DisplayOrder": 410,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 1,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 9530,
            "LocalizeKR": "그때의, 홈런공이에요.",
            "LocalizeJP": "思い出の、\nホームランボールです。",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle1",
            "AnimationName": "",
            "Anniversary": 0,
