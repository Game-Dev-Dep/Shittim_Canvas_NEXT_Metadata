            "ActionName": "",
            "DialogType": 0,
            "Duration": 6833,
            "LocalizeKR": "자, 선생님. 하나 줄게.",
            "LocalizeJP": "はい、先生。一個あげる、",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle1",
            "AnimationName": "Talk_01_M",
            "Anniversary": 0,
