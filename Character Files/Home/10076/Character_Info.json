            "GroupId": 5,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 7600,
            "LocalizeKR": "못난 모습을……\n보이고 말았어요……",
            "LocalizeJP": "ダメダメな姿を……\n見られて、しまいました……",
            "VoiceIds": [],
