                        "GroupId": 1,
                        "ActionName": "",
                        "DialogType": 0,
                        "Duration": 2680,
                        "LocalizeKR": "오늘을 위해\n만들어 봤지.",
                        "LocalizeJP": "今日のために\n作ったの。",
                        "VoiceIds": [],
                        "CollectionVisible": false,
                        "CVCollectionType": 0,
                        "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle1",
                        "AnimationName": "",
                        "Anniversary": 0,
