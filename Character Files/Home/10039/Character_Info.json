            "DisplayOrder": 390,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 5,
            "ActionName": "",
            "DialogType": 1,
            "Duration": 7700,
            "LocalizeKR": "(으으……\n서, 선생님의 숨결이,\n가까이에서……)",
            "LocalizeJP": "（うぅ……せ、先生の\n吐息が、この距離で……）",
            "VoiceIds": [],
            "CollectionVisible": false,
