          },
          {
            "CharacterId": 10072,
            "CostumeUniqueId": 1007201,
            "DisplayOrder": 420,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 1,
            "ActionName": "",
            "DialogType": 1,
            "Duration": 11550,
            "LocalizeKR": "(그래, 천천히.\n천천히 숨을 내쉬는 거야.)",
            "LocalizeJP": "（そうそう、ゆっくり。\n息をゆっくり吐いて）",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle1",
            "AnimationName": "",
            "Anniversary": 0,
