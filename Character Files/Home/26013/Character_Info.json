            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 2,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 11167,
            "LocalizeKR": "좀 더 꽃 쪽으로 붙어……?\n알았어.",
