            "DisplayOrder": 550,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 5,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 8980,
            "LocalizeKR": "'악보도 많이 샀으니까'요……?",
            "LocalizeJP": "「楽譜もたくさん\n買ったから」……？",
            "VoiceIds": [],
