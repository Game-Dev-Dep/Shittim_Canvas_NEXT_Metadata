            "GroupId": 5,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 10000,
            "LocalizeKR": "선생님……\n감사합니다……\n히히……",
            "LocalizeJP": "先生……\nありがとうございます……\nひひ……。",
