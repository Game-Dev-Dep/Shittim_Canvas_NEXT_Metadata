            "DisplayOrder": 700,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 4,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 11950,
            "LocalizeKR": "그럼, 히어로와 사이드킥의\n조촐한 저녁 식사야.\n…비상식량이지만.",
            "LocalizeJP": "んじゃ、ヒーローと相棒の\n質素な夕食にしよっか。\n…非常食だけど。",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle4",
            "AnimationName": "",
            "Anniversary": 0,
