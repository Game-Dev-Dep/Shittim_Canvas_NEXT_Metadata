    "Entries": [
      {
        "Region": 3,
        "CharacterDialogInfo_List": [
          {
            "CharacterId": 10085,
            "CostumeUniqueId": 1008501,
            "DisplayOrder": 390,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 1,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 6100,
            "LocalizeKR": "하늘에 빛이 가득해…",
            "LocalizeJP": "空が、光でいっぱい…。",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle1",
            "AnimationName": "Talk_01_M",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 10085,
            "CostumeUniqueId": 1008501,
            "DisplayOrder": 400,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 1,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 9600,
            "LocalizeKR": "이렇게 반짝이는\n밤하늘은\n처음인 것 같아.",
            "LocalizeJP": "こんなに\nきらきらした夜空は、\nはじめてかも。",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle1",
            "AnimationName": "",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 10085,
            "CostumeUniqueId": 1008501,
            "DisplayOrder": 410,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 2,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 10650,
            "LocalizeKR": "저 빛나는 점 하나하나가\n방대한 정보를 담은\n노드라고 생각하면",
            "LocalizeJP": "あの光一つ一つが、\n膨大な情報を持つ\nノードだと思うと",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle2",
            "AnimationName": "Talk_02_M",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 10085,
            "CostumeUniqueId": 1008501,
            "DisplayOrder": 420,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 2,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 9850,
            "LocalizeKR": "새삼 경외감이 느껴질 정도네.",
            "LocalizeJP": "なんか、畏敬の念すら\n覚えるかも。",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle2",
            "AnimationName": "",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 10085,
            "CostumeUniqueId": 1008501,
            "DisplayOrder": 430,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 3,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 6950,
            "LocalizeKR": "내가 알고 있는 모든\n정보를 쌓는다 해도",
            "LocalizeJP": "私の知っている\n情報をすべて重ねても",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle3",
            "AnimationName": "Talk_03_M",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 10085,
            "CostumeUniqueId": 1008501,
            "DisplayOrder": 440,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 3,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 9050,
            "LocalizeKR": "저 빛에는 차마 닿지 못하겠지.",
            "LocalizeJP": "あの光には、\n届かないんだろうな…",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle3",
            "AnimationName": "",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 10085,
            "CostumeUniqueId": 1008501,
            "DisplayOrder": 450,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 4,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 6150,
            "LocalizeKR": "…하지만 나는\n포기하지 않을 거야.",
            "LocalizeJP": "…それでも私は、諦めない。",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle4",
            "AnimationName": "Talk_04_M",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 10085,
            "CostumeUniqueId": 1008501,
            "DisplayOrder": 460,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 4,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 9050,
            "LocalizeKR": "진리는 언제나\n빛을 향하는 법이니까.",
            "LocalizeJP": "真理は必ず、\n光を向くものだから。",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle4",
            "AnimationName": "",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 10085,
            "CostumeUniqueId": 1008501,
            "DisplayOrder": 470,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 5,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 10400,
            "LocalizeKR": "하늘 위의 머나먼 별들에게\n경의를 담은 인사를.",
            "LocalizeJP": "空の上にある遠くの星へ、\n敬意を込めた挨拶を。",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle5",
            "AnimationName": "Talk_05_M",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
