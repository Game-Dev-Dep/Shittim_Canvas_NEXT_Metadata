            "DisplayOrder": 310,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 3,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 9033,
            "LocalizeKR": "분명, 벌을 받은 거예요.",
            "LocalizeJP": "きっと、罰が当たったんですよ。",
            "VoiceIds": [],
            "CollectionVisible": false,
