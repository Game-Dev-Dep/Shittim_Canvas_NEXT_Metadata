          },
          {
            "CharacterId": 16014,
            "CostumeUniqueId": 1601401,
            "DisplayOrder": 320,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 3,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 7940,
            "LocalizeKR": "에헤헤… 그럼 선생님에게, \n이부키 선생님의 문제입니다!",
            "LocalizeJP": "えへへっ……じゃあ先生に、\nイブキ先生から問題です！",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle3",
            "AnimationName": "Talk_03_M",
            "Anniversary": 0,
            "StartDate": "",
