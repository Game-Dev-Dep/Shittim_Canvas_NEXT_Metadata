          },
          {
            "CharacterId": 20019,
            "CostumeUniqueId": 2001901,
            "DisplayOrder": 410,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 5,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 14500,
            "LocalizeKR": "앞으로도, 부족한 몸이지만\n아무쪼록 잘 부탁드립니다.\n주인님.",
