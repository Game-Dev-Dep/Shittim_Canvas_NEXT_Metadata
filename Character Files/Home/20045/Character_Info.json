            "DisplayOrder": 350,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 4,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 10330,
            "LocalizeKR": "단둘이 있을 때에는……\n뭐랄까……",
            "LocalizeJP": "二人っきりだと……\nその……。",
            "VoiceIds": [],
            "CollectionVisible": false,
