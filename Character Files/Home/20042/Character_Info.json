            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 3,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 2270,
            "LocalizeKR": "주변에 즐길 거리도\n없다 보니……",
            "LocalizeJP": "他に娯楽もないしさー……",
            "VoiceIds": [],
            "CollectionVisible": false,
