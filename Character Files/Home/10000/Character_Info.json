          },
          {
            "CharacterId": 10000,
            "CostumeUniqueId": 1000001,
            "DisplayOrder": 360,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 6,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 3800,
            "LocalizeKR": "응?\n잘못 걸린 거 아니냐고?",
            "LocalizeJP": "ん？\n間違い電話じゃ\nないのかって？",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle6",
            "AnimationName": "Talk_06_M",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 10000,
            "CostumeUniqueId": 1000001,
            "DisplayOrder": 370,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 6,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 7200,
            "LocalizeKR": "무, 무슨 얘길 하는 거야?\n일하는 중이잖아!",
            "LocalizeJP": "な、何言ってるの？\nちゃんと仕事中よ！",
