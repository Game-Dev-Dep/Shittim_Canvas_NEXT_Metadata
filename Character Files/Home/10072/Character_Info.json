            "ActionName": "",
            "DialogType": 1,
            "Duration": 4450,
            "LocalizeKR": "(자, 선생님.\n진정하고 이쪽을 봐.)",
            "LocalizeJP": "（さあ、先生。\n落ち着いて、\nこっちを見るんだ）",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle1",
            "AnimationName": "Talk_01_M",
            "Anniversary": 0,
