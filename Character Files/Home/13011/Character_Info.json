          },
          {
            "CharacterId": 13011,
            "CostumeUniqueId": 1301101,
            "DisplayOrder": 300,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 3,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 7300,
            "LocalizeKR": "얼굴이 땀으로 범벅이네?!\n괜찮아?",
            "LocalizeJP": "汗まみれじゃん！\n大丈夫！？",
