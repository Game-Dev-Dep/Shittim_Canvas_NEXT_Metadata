          },
          {
            "CharacterId": 10127,
            "CostumeUniqueId": 1012701,
            "DisplayOrder": 300,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 3,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 7800,
            "LocalizeKR": "흐음, 악몽인가요.",
            "LocalizeJP": "なるほど、悪夢……。",
