          },
          {
            "CharacterId": 10053,
            "CostumeUniqueId": 1005301,
            "DisplayOrder": 550,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 4,
            "ActionName": "",
            "DialogType": 1,
            "Duration": 9450,
            "LocalizeKR": "(그런 파렴치한 짓이\n용납될 리가…!)",
            "LocalizeJP": "（そんな破廉恥なことが\n許されるわけ……！）",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle4",
            "AnimationName": "",
            "Anniversary": 0,
