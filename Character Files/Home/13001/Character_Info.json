            "DisplayOrder": 320,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 3,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 6750,
            "LocalizeKR": "둘의 발소리",
            "LocalizeJP": "音ふたつ",
            "VoiceIds": [],
