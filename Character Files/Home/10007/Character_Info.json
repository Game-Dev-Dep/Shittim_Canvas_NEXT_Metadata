          },
          {
            "CharacterId": 10007,
            "CostumeUniqueId": 1000701,
            "DisplayOrder": 360,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 4,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 10000,
            "LocalizeKR": "높아서 무섭지 않냐고?\n괜찮아, 선생님이 옆에 있으니까.",
            "LocalizeJP": "こんな高いところで\n怖くないのかって？\n大丈夫、\n先生がそばにいるから。",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle4",
            "AnimationName": "Talk_04_M",
            "Anniversary": 0,
