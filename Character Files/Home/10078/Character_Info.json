        "CharacterDialogInfo_List": [
          {
            "CharacterId": 10078,
            "CostumeUniqueId": 1007801,
            "DisplayOrder": 300,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 1,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 5500,
            "LocalizeKR": "와~핫핫핫하!\n딱 좋은 타이밍에 왔네!",
            "LocalizeJP": "ハーハッハッハッハ！\nちょうど良いところに来たな！",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle1",
            "AnimationName": "Talk_01_M",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 10078,
            "CostumeUniqueId": 1007801,
            "DisplayOrder": 310,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 1,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 10833,
            "LocalizeKR": "잘 왔어, 선생님~.\n여기가 나의 86번째\n비밀 아지트다.",
            "LocalizeJP": "ようこそ、先生。\nここが私の第86秘密アジトだ。",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle1",
            "AnimationName": "",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 10078,
            "CostumeUniqueId": 1007801,
            "DisplayOrder": 320,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 2,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 8800,
            "LocalizeKR": "여기서 뭐 하냐고?\n우문이네, 선생님.\n내가 하는 일이라면 단 하나.",
            "LocalizeJP": "ここで何をしているのかって？\n愚問だな、先生。\n私がすることといえばただ一つ。",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle2",
            "AnimationName": "Talk_02_M",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 10078,
            "CostumeUniqueId": 1007801,
            "DisplayOrder": 330,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 2,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 11033,
            "LocalizeKR": "바로…… 새로운 온천\n포인트를 찾고 있다~\n이 말이야!",
            "LocalizeJP": "すなわち……\n新たな温泉ポイントを\n探しているのだ！",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle2",
            "AnimationName": "",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 10078,
            "CostumeUniqueId": 1007801,
            "DisplayOrder": 340,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 3,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 4700,
            "LocalizeKR": "하핫, 선생님.\n대화가 통해서 좋구만.",
            "LocalizeJP": "ハハッ、先生。\n話が早くて助かるな。",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle3",
            "AnimationName": "Talk_03_M",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 10078,
            "CostumeUniqueId": 1007801,
            "DisplayOrder": 350,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 3,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 10633,
            "LocalizeKR": "아아, 맞아.\n실제로 폭파시킬 곳 주변을\n좀 맞춰보고 있었다는 거지.",
            "LocalizeJP": "ああ、その通り。\n実際に爆破する場所に\nあたりをつけていたのだよ。",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle3",
            "AnimationName": "",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 10078,
            "CostumeUniqueId": 1007801,
            "DisplayOrder": 360,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 4,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 4400,
            "LocalizeKR": "흠……\n여기가 좋을까?",
            "LocalizeJP": "ふむ……\nここが良いだろうか？",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle4",
            "AnimationName": "Talk_04_M",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 10078,
            "CostumeUniqueId": 1007801,
            "DisplayOrder": 370,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 4,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 8100,
            "LocalizeKR": "아니……\n이쪽도 그럭저럭……",
            "LocalizeJP": "いや……\nこっちもなかなか……",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle4",
            "AnimationName": "",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
