            "GroupId": 5,
            "ActionName": "",
            "DialogType": 1,
            "Duration": 5100,
            "LocalizeKR": "(하지만… 선생님이라면…)",
            "LocalizeJP": "（でも……先生なら……）",
            "VoiceIds": [],
            "CollectionVisible": false,
