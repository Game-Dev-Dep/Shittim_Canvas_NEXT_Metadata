            "DisplayOrder": 440,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 1,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 9500,
            "LocalizeKR": "또 같은 지점에서\n죽어버렸어……",
            "LocalizeJP": "また同じとこで\n死んじゃった……。",
            "VoiceIds": [],
            "CollectionVisible": false,
