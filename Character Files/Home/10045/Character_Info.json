            "GroupId": 5,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 5500,
            "LocalizeKR": "딱히 그런 부분…\n싫어하진 않지만.",
            "LocalizeJP": "まあ、そういうところ\n嫌いじゃないけど。",
            "VoiceIds": [],
