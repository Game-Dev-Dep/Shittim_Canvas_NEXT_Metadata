            "DisplayOrder": 280,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 1,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 11333,
            "LocalizeKR": "이럴 때, 어떻게 하면\n좋을지 모르겠네……",
