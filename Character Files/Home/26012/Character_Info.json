            "GroupId": 2,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 3620,
            "LocalizeKR": "큰일 난 줄 알았습니다.",
            "LocalizeJP": "大変なことに\nなってしまったのかと\n思いました。",
            "VoiceIds": [],
            "CollectionVisible": false,
