            "PopupFileName": "",
            "ScriptKr": "#st;[-1200,-630];serial;60;― (언젠가는 [wa:400]이렇게 옆에서……. [wa:3500]나란히 걷는 날도 오지 않을까…?)",
            "TextJp": "― （いつか[wa:400]こうやって隣に……[wa:2000]堂々と、[wa:1400]並んで歩ける日が……）",
            "VoiceId": 0
          },
          {
            "ByteBuffer": {
              "Position": 0,
              "Length": 96
            },
            "GroupId": 2600506,
            "SelectionGroup": 0,
