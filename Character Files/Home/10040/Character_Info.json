            "BGName": 0,
            "BGEffect": 0,
            "PopupFileName": "",
            "ScriptKr": "3;츠쿠요;01\n#3;a\n#wait;1000",
            "TextJp": "",
            "VoiceId": 0
          },
          {
            "ByteBuffer": {
              "Position": 0,
              "Length": 240
            },
            "GroupId": 1004006,
