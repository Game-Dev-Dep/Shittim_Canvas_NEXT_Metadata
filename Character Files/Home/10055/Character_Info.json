            "ActionName": "",
            "DialogType": 0,
            "Duration": 2800,
            "LocalizeKR": "아름다운 야경이네……",
            "LocalizeJP": "綺麗な夜景だね……。",
            "VoiceIds": [],
            "CollectionVisible": false,
