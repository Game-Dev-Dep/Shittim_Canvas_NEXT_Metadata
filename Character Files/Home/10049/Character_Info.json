            "DisplayOrder": 300,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 3,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 5000,
            "LocalizeKR": "너무 가까운 건 좀……!",
            "LocalizeJP": "あんまり、\n近づくのはちょっと……！",
            "VoiceIds": [],
            "CollectionVisible": false,
