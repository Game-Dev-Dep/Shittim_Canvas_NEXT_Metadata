            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 20027,
            "CostumeUniqueId": 2002701,
            "DisplayOrder": 360,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 2,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 8450,
            "LocalizeKR": "요리도구도\n준비해 뒀으니까,\n문제없어.",
            "LocalizeJP": "料理道具も準備したから、\n問題ない。",
