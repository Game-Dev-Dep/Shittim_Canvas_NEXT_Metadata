            "DisplayOrder": 300,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 2,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 3780,
            "LocalizeKR": "이부키, 산수는 자신 있어!",
            "LocalizeJP": "イブキ、\nさんすうは\n自信あるんだ！",
            "VoiceIds": [],
            "CollectionVisible": false,
