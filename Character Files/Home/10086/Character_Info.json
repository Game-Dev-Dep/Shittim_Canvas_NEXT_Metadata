            "DisplayOrder": 520,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 4,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 5100,
            "LocalizeKR": "아……\n으, 으응……",
            "LocalizeJP": "あ……\nう、うーん……",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle4",
            "AnimationName": "Talk_04_M",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 10086,
            "CostumeUniqueId": 1008601,
            "DisplayOrder": 530,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 4,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 10233,
            "LocalizeKR": "그래……\n당신은, 늘 그랬지.",
            "LocalizeJP": "そう……あなたは、\nいつもそうだった。",
            "VoiceIds": [],
            "CollectionVisible": false,
