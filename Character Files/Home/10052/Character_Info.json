            "DisplayOrder": 430,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 1,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 7360,
            "LocalizeKR": "종이에 글씨를 쓸 때와는 달리,\n기분이 고양되는 것 같아요.",
            "LocalizeJP": "紙に文字を書くときと違って、\n気分が高揚しています。",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle1",
            "AnimationName": "",
            "Anniversary": 0,
