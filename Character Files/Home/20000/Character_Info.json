            "GroupId": 4,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 6500,
            "LocalizeKR": "좀 더…\n함께 있어줄래?",
            "LocalizeJP": "もう少し…\n一緒にいてくれる？",
