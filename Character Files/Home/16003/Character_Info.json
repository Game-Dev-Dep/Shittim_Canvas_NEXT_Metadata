          },
          {
            "CharacterId": 16003,
            "CostumeUniqueId": 1600301,
            "DisplayOrder": 250,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 1,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 8700,
            "LocalizeKR": "여기서라면, 별을\n잡을 수 있을 것만 같아요.",
            "LocalizeJP": "ここからなら、\n星が掴めてしまいそうです。",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle1",
            "AnimationName": "",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 16003,
            "CostumeUniqueId": 1600301,
            "DisplayOrder": 260,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 2,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 7900,
            "LocalizeKR": "최근에는 이렇게 느긋하고,\n차분한 시간도\n보낼 수 있게 되었네요……",
            "LocalizeJP": "ここ最近はこうしてゆっくりと、\n落ち着いた時間も\n過ごすことができて……。",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle2",
            "AnimationName": "Talk_02_M",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 16003,
            "CostumeUniqueId": 1600301,
            "DisplayOrder": 270,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 2,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 8600,
            "LocalizeKR": "……선생님과\n만났을 무렵부터,\n인지도 모릅니다.",
            "LocalizeJP": "……先生と出会った頃から、\nかもしれません。",
