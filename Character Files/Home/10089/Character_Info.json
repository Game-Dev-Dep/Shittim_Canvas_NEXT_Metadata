            "DisplayOrder": 390,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 3,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 2850,
            "LocalizeKR": "각자 이유는 달라도……",
            "LocalizeJP": "それぞれ理由は違っても……",
