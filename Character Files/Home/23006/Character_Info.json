            "GroupId": 2,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 10500,
            "LocalizeKR": "네에네에~ 보시다시피\n현재진행형으로\n땡땡이 중이에요오~",
            "LocalizeJP": "そうですよぉ～。\n見ての通り、現在進行形で\nおサボり中で～す。",
            "VoiceIds": [],
            "CollectionVisible": false,
