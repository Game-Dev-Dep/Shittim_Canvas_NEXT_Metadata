            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 20025,
            "CostumeUniqueId": 2002501,
            "DisplayOrder": 310,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 1,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 13133,
            "LocalizeKR": "아니요! 그게, 딱히 따지는 건\n아닙니다만!! 정말로!!",
            "LocalizeJP": "い、いえ！その、\n別に問い詰めているつもりでは\nないんですけど！！本当に！！",
