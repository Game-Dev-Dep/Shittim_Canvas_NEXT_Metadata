            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 4,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 12300,
            "LocalizeKR": "그럼 마, 맛있게……\n드, 드셔주세요……",
            "LocalizeJP": "じゃあ、お、おいしく……\nめ、召し上がって\nください……。",
