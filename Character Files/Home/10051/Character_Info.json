  "Subtitles": {
    "Entries": [
      {
        "Region": 3,
        "CharacterDialogInfo_List": [
          {
            "CharacterId": 10051,
            "CostumeUniqueId": 1005101,
            "DisplayOrder": 310,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 1,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 4250,
            "LocalizeKR": "플레이, 플레이! 밀레니엄!",
            "LocalizeJP": "フレー！フレー！\nミレニアム！",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle1",
            "AnimationName": "Talk_01_M",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 10051,
            "CostumeUniqueId": 1005101,
            "DisplayOrder": 320,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 1,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 8250,
            "LocalizeKR": "싸워라! 이겨라! 밀레니엄!",
            "LocalizeJP": "行け！行け！勝て！勝て！\nミレニアム！",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle1",
            "AnimationName": "",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 10051,
            "CostumeUniqueId": 1005101,
            "DisplayOrder": 330,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 2,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 6400,
            "LocalizeKR": "후후… 어때, 선생님?\n대단한 광경이라고\n생각되지 않아?",
            "LocalizeJP": "ふふ… どうだい、先生？\nすごい光景だと思わないか？",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle2",
            "AnimationName": "Talk_02_M",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 10051,
            "CostumeUniqueId": 1005101,
            "DisplayOrder": 340,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 2,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 5200,
            "LocalizeKR": "이 매스게임에는\n신형 블루투스 장치를\n탑재한 로봇을\n사용하고 있기 때문에,",
            "LocalizeJP": "このマスゲームには、\n新型ブルートゥース装置を\n搭載したロボットを\n使用しているから、",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle2",
            "AnimationName": "",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 10051,
            "CostumeUniqueId": 1005101,
            "DisplayOrder": 350,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 2,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 10400,
            "LocalizeKR": "아무리 복잡한 군무라도\n완벽하게 연출할 수 있어.",
            "LocalizeJP": "どんなに複雑な振付でも\n完璧に演出する\nことができるんだ。",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle2",
            "AnimationName": "",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 10051,
            "CostumeUniqueId": 1005101,
            "DisplayOrder": 360,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 3,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 12500,
            "LocalizeKR": "…응?\n연출에 기계를 사용할 거라면\n전광판을 설치하는 게\n더 효율적이지 않겠느냐고?",
            "LocalizeJP": "…うん？演出に機械を\n使用するぐらいなら、\nスクリーンを設置したほうが\n効率的なのではないのかって？",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle3",
            "AnimationName": "Talk_03_M",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 10051,
            "CostumeUniqueId": 1005101,
            "DisplayOrder": 370,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 4,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 5300,
            "LocalizeKR": "선생님,\n낭만이 없는 이야기는\n하지 말아줘.",
            "LocalizeJP": "先生、\nロマンのない話は\n辞めたまえ。",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle4",
            "AnimationName": "Talk_04_M",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 10051,
            "CostumeUniqueId": 1005101,
            "DisplayOrder": 380,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 4,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 3800,
            "LocalizeKR": "아날로그 패널이\n동시에 펼쳐지며\n완성하는 풍경에는",
            "LocalizeJP": "アナログのパネルが一斉に\n動いて完成される光景には、",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle4",
            "AnimationName": "",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 10051,
            "CostumeUniqueId": 1005101,
            "DisplayOrder": 390,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 4,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 8800,
            "LocalizeKR": "전광판은 비교도\n되지 않을 정도의\n박력과 감동이 있으니까.",
            "LocalizeJP": "スクリーンとは比べ物に\nならないほどの迫力と\n感動があるんだよ。",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle4",
            "AnimationName": "",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 10051,
            "CostumeUniqueId": 1005101,
            "DisplayOrder": 400,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 5,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 11500,
            "LocalizeKR": "본래 사람의 가슴을 뛰게\n만드는 로망은 효율과는\n거리가 먼 법이거든.",
            "LocalizeJP": "元来、胸高鳴る瞬間を\n与えるロマンは、「効率」とは\n程遠いものだからね。",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle5",
            "AnimationName": "Talk_05_M",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          }
        ],
