            "DisplayOrder": 590,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 4,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 9000,
            "LocalizeKR": "이 차갑고\n시끄러운 세계도……\n나도.",
