            "DisplayOrder": 350,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 1,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 9370,
            "LocalizeKR": "제가 지켜낸 세계예요.",
            "LocalizeJP": "わたしが守り抜いた世界です。",
            "VoiceIds": [],
            "CollectionVisible": false,
