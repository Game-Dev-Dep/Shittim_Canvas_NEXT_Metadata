          },
          {
            "CharacterId": 10072,
            "CostumeUniqueId": 1007201,
            "DisplayOrder": 450,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 3,
            "ActionName": "",
            "DialogType": 1,
            "Duration": 7400,
            "LocalizeKR": "(바닷속에서 선생님과 단둘이, \n아무 말 없이 시선과\n손짓만으로 대화를 하려니…)",
            "LocalizeJP": "（海の中で先生と\n二人きり、言葉もなく\n視線とジェスチャーだけで\n会話していると…）",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle3",
            "AnimationName": "",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 10072,
            "CostumeUniqueId": 1007201,
            "DisplayOrder": 460,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 3,
            "ActionName": "",
            "DialogType": 1,
            "Duration": 7800,
            "LocalizeKR": "(마치 뭔가…)",
            "LocalizeJP": "（まるで…）",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle3",
            "AnimationName": "",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
