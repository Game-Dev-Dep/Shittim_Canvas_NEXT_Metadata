            "DisplayOrder": 360,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 5,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 7250,
            "LocalizeKR": "'간식이 3개나 있으면\n너무 행복해~'야!",
            "LocalizeJP": "「おやつが3コもあったら\nすっごく幸せ～」だよ！",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle5",
            "AnimationName": "Talk_05_M",
