            "DisplayOrder": 370,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 4,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 5300,
            "LocalizeKR": "응? 그 표정은 뭔가요?",
            "LocalizeJP": "うん？その表情、\nどうかなさいまして？",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
