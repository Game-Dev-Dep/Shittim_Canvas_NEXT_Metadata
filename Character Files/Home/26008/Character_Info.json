  "Subtitles": {
    "Entries": [
      {
        "Region": 3,
        "CharacterDialogInfo_List": [
          {
            "CharacterId": 26008,
            "CostumeUniqueId": 2600801,
            "DisplayOrder": 390,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 1,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 6350,
            "LocalizeKR": "선생님, 저,\n제가 해야 할 일을 알았어요.",
            "LocalizeJP": "先生。私、\n自分のするべき\nことが分かりました。",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle1",
            "AnimationName": "Talk_01_M",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 26008,
            "CostumeUniqueId": 2600801,
            "DisplayOrder": 400,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 1,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 12150,
            "LocalizeKR": "생각해 보면\n당연한 거였는데,\n이제서야 깨닫다니…\n시즈코, 일생의 불찰!",
            "LocalizeJP": "考えてみれば\n当たり前のことなのに、\n今になって気づくとは…\nシズコ、一生の不覚！",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle1",
            "AnimationName": "",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 26008,
            "CostumeUniqueId": 2600801,
            "DisplayOrder": 410,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 2,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 5100,
            "LocalizeKR": "알고 계실지도 모르겠지만,\n전 정말 욕심꾸러기라구요?",
            "LocalizeJP": "知ってるかもしれませんが、\n私って欲張りなんですよ？",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle2",
            "AnimationName": "Talk_02_M",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 26008,
            "CostumeUniqueId": 2600801,
            "DisplayOrder": 420,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 2,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 9400,
            "LocalizeKR": "하고 싶은 것도,\n갖고 싶은 것도 많지만,\n그 중 하나도\n포기할 수 없어요.",
            "LocalizeJP": "やりたいことも、\n欲しい物も\nたくさんありますが、\n一つも諦めません。",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle2",
            "AnimationName": "",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 26008,
            "CostumeUniqueId": 2600801,
            "DisplayOrder": 430,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 3,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 4700,
            "LocalizeKR": "모두를 즐겁게 하는 것도,\n사업가로 성공하는 것도!",
            "LocalizeJP": "みんなを喜ばせることも、\n商売としての成功も！",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle3",
            "AnimationName": "Talk_03_M",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 26008,
            "CostumeUniqueId": 2600801,
            "DisplayOrder": 440,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 3,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 8300,
            "LocalizeKR": "백야당을 키보토스\n최고의 찻집으로\n만드는 것도!",
            "LocalizeJP": "百夜堂を、\nキヴォトスいちの\n喫茶店にすることも！",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle3",
            "AnimationName": "",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 26008,
            "CostumeUniqueId": 2600801,
            "DisplayOrder": 450,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 4,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 5500,
            "LocalizeKR": "저는, 전부\n놓치고 싶지 않아요.\n전부!",
            "LocalizeJP": "私、全部\n逃したくないんです！\n全部！",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle4",
            "AnimationName": "Talk_04_M",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          },
          {
            "CharacterId": 26008,
            "CostumeUniqueId": 2600801,
            "DisplayOrder": 460,
            "DialogCategory": 8,
            "DialogCondition": 0,
            "GroupId": 4,
            "ActionName": "",
            "DialogType": 0,
            "Duration": 7500,
            "LocalizeKR": "물론… 선생님도요!",
            "LocalizeJP": "もちろん…\n先生のことも！",
            "VoiceIds": [],
            "CollectionVisible": false,
            "CVCollectionType": 0,
            "LocalizeCVGroup": "CVGroup_UILobbySpecial_Idle4",
            "AnimationName": "",
            "Anniversary": 0,
            "StartDate": "",
            "EndDate": "",
            "ApplyPosition": false,
            "PosX": 0.0,
            "PosY": 0.0,
            "UnlockFavorRank": 0,
            "UnlockEquipWeapon": false
          }
        ],
